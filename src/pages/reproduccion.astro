---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getSession } from '../lib/auth';
import { readSheet } from '../lib/sheets';

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect('/login');
let registros: any[] = [];
let errorMsg = '';
try { registros = await readSheet('Reproduccion'); } catch (e: any) { errorMsg = e.message; }
---

<DashboardLayout title="Reproduccion" userName={session.nombre} rol={session.rol} currentPage="reproduccion" chatData={{}}>
  <div class="page-header">
    <div><h1>Reproduccion</h1><p>Control reproductivo &middot; <span class="font-medium">{registros.length} eventos</span></p></div>
    <button onclick="abrirModal()" class="btn btn-primary cursor-pointer"><i class="fas fa-plus text-xs"></i> Nuevo Evento</button>
  </div>
  {errorMsg ? <div class="card p-5 bg-red-50 border-red-200 text-red-700 text-sm">{errorMsg}</div> : registros.length === 0 ? (
    <div class="card"><div class="empty-state"><div class="empty-state-icon"><i class="fas fa-dna"></i></div><h3>Sin registros reproductivos</h3><p>Registra empadres, gestaciones y partos de tu ganado.</p><button onclick="abrirModal()" class="btn btn-primary cursor-pointer"><i class="fas fa-plus text-xs"></i> Nuevo evento</button></div></div>
  ) : (
    <div class="card-flush"><div class="table-wrap"><table class="table-modern"><thead><tr><th>Fecha</th><th>Hembra</th><th>Evento</th><th>Resultado</th><th>Macho</th><th>Parto Probable</th></tr></thead><tbody>
      {registros.map((r: any) => {
        const rc = r.resultado==='Positivo'?'success':r.resultado==='Negativo'?'danger':'warning';
        return (
          <tr><td class="text-slate-400 text-xs">{r.fecha_evento||'-'}</td><td class="font-mono text-xs font-medium text-brand-700">{r.id_animal_hembra}</td><td class="text-slate-700">{r.tipo_evento||'-'}</td><td><span class={"badge-modern " + rc}>{r.resultado||'Pendiente'}</span></td><td class="font-mono text-xs text-slate-400">{r.id_macho||'-'}</td><td class="text-slate-400 text-xs">{r.fecha_probable_parto||'-'}</td></tr>
        );
      })}
    </tbody></table></div></div>
  )}
  <div id="modalRep" class="modal-backdrop hidden">
    <div class="modal-content max-w-md">
      <div class="modal-header"><div><h3>Nuevo Evento Reproductivo</h3></div><button onclick="cerrarModal()" class="btn-close"><i class="fas fa-times"></i></button></div>
      <form id="repForm">
        <div class="modal-body space-y-4">
          <div><label class="form-label">ID de la Hembra *</label><input id="rHem" class="form-input" required placeholder="ANI-00001" /></div>
          <div class="grid grid-cols-2 gap-4"><div><label class="form-label">Fecha *</label><input id="rFec" type="date" class="form-input" required /></div><div><label class="form-label">Tipo</label><select id="rTip" class="form-input"><option>Empadre/Monta</option><option>Inseminacion artificial</option><option>Diagnostico de gestacion</option><option>Parto</option><option>Aborto</option><option>Destete</option></select></div></div>
          <div><label class="form-label">ID del Macho</label><input id="rMac" class="form-input" placeholder="ANI-00002" /></div>
          <div><label class="form-label">Resultado</label><select id="rRes" class="form-input"><option>Pendiente</option><option>Positivo</option><option>Negativo</option></select></div>
        </div>
        <div class="modal-footer"><button type="button" onclick="cerrarModal()" class="btn btn-secondary">Cancelar</button><button type="submit" class="btn btn-primary"><i class="fas fa-save text-xs"></i> Guardar</button></div>
      </form>
    </div>
  </div>
</DashboardLayout>
<script is:inline>
  function abrirModal() { document.getElementById('modalRep').classList.remove('hidden'); }
  function cerrarModal() { document.getElementById('modalRep').classList.add('hidden'); }
  document.getElementById('repForm').addEventListener('submit', function(e) { e.preventDefault(); var d = { id_animal_hembra: document.getElementById('rHem').value, tipo_evento: document.getElementById('rTip').value, fecha_evento: document.getElementById('rFec').value, id_macho: document.getElementById('rMac').value, resultado: document.getElementById('rRes').value }; if (!d.id_animal_hembra || !d.fecha_evento) { showToast('Completa los campos', 'error'); return; }     fetch('/api/data/Reproduccion', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(d) }).then(function(r){ return r.json(); }).then(function(d){ if(d.error){showToast(d.error,'error');return;} cerrarModal(); showToast('Evento guardado','success'); setTimeout(function(){location.reload();},500); }).catch(function(){ showToast('Error de conexion','error'); }); });
</script>
