---
import Layout from '../layouts/Layout.astro';
import { getSession } from '../lib/auth';

const session = getSession(Astro.cookies);
if (session) return Astro.redirect('/dashboard');
---

<Layout title="AGROVELAS - Sistema de Gestion Ganadera Inteligente">
  <!-- NAV -->
  <nav id="navbar" class="fixed top-0 inset-x-0 z-50 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2.5 no-underline z-10">
          <div class="w-9 h-9 bg-gradient-to-br from-brand-500 to-emerald-500 rounded-xl flex items-center justify-center shadow-lg shadow-brand-600/30">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <span class="text-lg font-bold text-white tracking-tight">AGROVELAS</span>
        </a>

        <div class="hidden md:flex items-center gap-8">
          <a href="/" class="text-sm text-white font-medium no-underline relative after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-white after:rounded-full">Inicio</a>
          <a href="#modulos" class="text-sm text-white/70 hover:text-white transition-colors no-underline">Funcionalidades</a>
          <a href="#precios" class="text-sm text-white/70 hover:text-white transition-colors no-underline">Precios</a>
          <a href="/contacto" class="text-sm text-white/70 hover:text-white transition-colors no-underline">Contacto</a>
          <a href="#faq" class="text-sm text-white/70 hover:text-white transition-colors no-underline">FAQ</a>
          <a href="/acerca" class="text-sm text-white/70 hover:text-white transition-colors no-underline">Nosotros</a>
        </div>

        <div class="flex items-center gap-3">
          <a href="/login" class="hidden sm:inline-flex btn btn-sm text-white/80 hover:text-white no-underline bg-white/10 hover:bg-white/20">Ingresar</a>
          <a href="/registro" class="btn btn-sm bg-white text-brand-700 hover:bg-brand-50 no-underline shadow-lg shadow-brand-900/20">Crear Cuenta</a>
          <button id="menuBtn" class="md:hidden w-9 h-9 rounded-lg flex items-center justify-center text-white bg-white/10 hover:bg-white/20 transition-colors border-none cursor-pointer z-10" onclick="toggleMenu()">
            <i id="menuIcon" class="fas fa-bars text-sm"></i>
          </button>
        </div>
      </div>
    </div>
    <div id="mobileMenu" class="md:hidden fixed inset-0 z-40 bg-brand-950/98 backdrop-blur-xl flex flex-col items-center justify-center gap-8 translate-y-[-100%] opacity-0 transition-all duration-300 pointer-events-none">
      <a href="/" class="text-xl text-white font-semibold no-underline" onclick="toggleMenu()">Inicio</a>
      <a href="#modulos" class="text-xl text-white/70 hover:text-white no-underline" onclick="toggleMenu()">Funcionalidades</a>
      <a href="#precios" class="text-xl text-white/70 hover:text-white no-underline" onclick="toggleMenu()">Precios</a>
      <a href="/contacto" class="text-xl text-white/70 hover:text-white no-underline" onclick="toggleMenu()">Contacto</a>
      <a href="#faq" class="text-xl text-white/70 hover:text-white no-underline" onclick="toggleMenu()">FAQ</a>
      <a href="/acerca" class="text-xl text-white/70 hover:text-white no-underline" onclick="toggleMenu()">Nosotros</a>
      <div class="flex gap-4 mt-4"><a href="/login" class="btn btn-lg bg-white/10 text-white no-underline" onclick="toggleMenu()">Ingresar</a><a href="/registro" class="btn btn-lg bg-white text-brand-700 no-underline" onclick="toggleMenu()">Crear Cuenta</a></div>
    </div>
  </nav>

  <style>
    #mobileMenu.open { transform: translateY(0); opacity: 1; pointer-events: all; }
  </style>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center overflow-hidden" style="background: linear-gradient(160deg, #022c22 0%, #064e3b 30%, #065f46 55%, #047857 80%, #059669 100%);">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="hero-orb hero-orb-1"></div>
      <div class="hero-orb hero-orb-2"></div>
      <div class="hero-orb hero-orb-3"></div>
      <div class="absolute bottom-0 inset-x-0 h-48 bg-gradient-to-t from-emerald-950/40 to-transparent"></div>
      <svg class="absolute bottom-0 inset-x-0 w-full" viewBox="0 0 1440 120" preserveAspectRatio="none" style="height:80px;"><path d="M0 60C240 120 480 0 720 30s480-30 720 0v90H0V60z" fill="#f8fafc" opacity="0.04"/></svg>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 md:py-40 w-full">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="anim-fade-up" style="animation-delay: 0.1s">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/20 text-white/80 text-xs font-medium mb-8 backdrop-blur-sm">
            <span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-brand-400"></span></span>
            Hecho en Cusco &mdash; Peru
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white leading-[1.05] text-balance mb-6 tracking-tight">
            Gestion ganadera <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-300 via-emerald-200 to-brand-300">inteligente</span>
          </h1>
          <p class="text-lg text-brand-100/80 leading-relaxed mb-10 max-w-lg">
            Digitaliza el control de tu ganado: sanidad, reproduccion, trazabilidad, esquila, finanzas y geolocalizacion IoT. Diseñado para productores altoandinos.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/registro" class="btn btn-primary btn-lg no-underline shadow-xl shadow-brand-900/30 group">
              Comenzar Gratis
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#modulos" class="btn btn-lg border border-white/20 text-white hover:bg-white/10 no-underline backdrop-blur-sm">Ver Modulos</a>
          </div>

          <div class="flex items-center gap-6 mt-12 pt-8 border-t border-white/10">
            <div class="flex -space-x-2">
              <div class="w-9 h-9 rounded-full border-2 border-emerald-700 bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center text-white text-[10px] font-bold shadow-lg">JM</div>
              <div class="w-9 h-9 rounded-full border-2 border-emerald-700 bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center text-white text-[10px] font-bold shadow-lg">RV</div>
              <div class="w-9 h-9 rounded-full border-2 border-emerald-700 bg-gradient-to-br from-violet-400 to-violet-600 flex items-center justify-center text-white text-[10px] font-bold shadow-lg">AL</div>
              <div class="w-9 h-9 rounded-full border-2 border-emerald-700 bg-gradient-to-br from-rose-400 to-rose-600 flex items-center justify-center text-white text-[10px] font-bold shadow-lg">+</div>
            </div>
            <div>
              <p class="text-sm font-semibold text-white">+120 productores</p>
              <p class="text-xs text-brand-200/60">confian en AGROVELAS</p>
            </div>
          </div>
        </div>

        <div class="hidden lg:flex items-center justify-center anim-slide-right" style="animation-delay: 0.3s">
          <div class="relative w-full max-w-lg">
            <div class="absolute -inset-6 bg-gradient-to-r from-brand-500/20 via-emerald-400/10 to-transparent rounded-[3rem] blur-3xl"></div>
            <div class="relative glass-dark rounded-[2rem] p-8 space-y-6">
              <div class="grid grid-cols-2 gap-4">
                <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 text-center border border-white/10 hover:bg-white/[0.15] transition-all group">
                  <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-brand-400 to-emerald-500 flex items-center justify-center mx-auto mb-3 shadow-lg"><span class="text-white font-bold text-lg">22</span></div>
                  <p class="text-white font-semibold text-sm">Modulos</p>
                  <p class="text-xs text-white/50 mt-0.5">Integrados</p>
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 text-center border border-white/10 hover:bg-white/[0.15] transition-all group">
                  <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center mx-auto mb-3 shadow-lg"><i class="fas fa-satellite-dish text-white text-lg"></i></div>
                  <p class="text-white font-semibold text-sm">IoT</p>
                  <p class="text-xs text-white/50 mt-0.5">Tiempo real</p>
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 text-center border border-white/10 hover:bg-white/[0.15] transition-all group">
                  <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center mx-auto mb-3 shadow-lg"><i class="fas fa-qrcode text-white text-lg"></i></div>
                  <p class="text-white font-semibold text-sm">QR</p>
                  <p class="text-xs text-white/50 mt-0.5">Trazabilidad</p>
                </div>
                <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 text-center border border-white/10 hover:bg-white/[0.15] transition-all group">
                  <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-400 to-teal-500 flex items-center justify-center mx-auto mb-3 shadow-lg"><i class="fas fa-coins text-white text-lg"></i></div>
                  <p class="text-white font-semibold text-sm">S/</p>
                  <p class="text-xs text-white/50 mt-0.5">Finanzas</p>
                </div>
              </div>
              <div class="bg-white/5 rounded-xl p-4 backdrop-blur-sm border border-white/5">
                <div class="flex items-center gap-3"><div class="w-2 h-2 rounded-full bg-brand-400"></div><p class="text-sm text-white/60">Sincronizado con Google Sheets</p></div>
                <div class="flex items-center gap-3 mt-2"><div class="w-2 h-2 rounded-full bg-brand-400"></div><p class="text-sm text-white/60">Codigo abierto &middot; Sin mensualidades</p></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 inset-x-0 flex justify-center z-10">
      <a href="#stats" class="text-white/40 hover:text-white/70 transition-colors inline-flex flex-col items-center gap-1">
        <span class="text-[10px] uppercase tracking-widest">Scroll</span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
      </a>
    </div>
  </section>

  <!-- STATS -->
  <section id="stats" class="py-20 relative overflow-hidden" style="background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/4 w-72 h-72 bg-brand-200/30 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-blue-200/20 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="glass rounded-2xl p-6 text-center scroll-animate">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-brand-500 to-emerald-500 flex items-center justify-center mx-auto mb-3 shadow-lg shadow-brand-200"><span class="text-white font-bold text-lg"><span class="counter" data-target="22">0</span></span></div>
          <p class="text-lg font-bold text-slate-900">Modulos</p>
          <p class="text-sm text-slate-500">Gestion integral</p>
        </div>
        <div class="glass rounded-2xl p-6 text-center scroll-animate">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center mx-auto mb-3 shadow-lg shadow-blue-200"><i class="fas fa-users text-white"></i></div>
          <p class="text-lg font-bold text-slate-900"><span class="counter" data-target="120">0</span>+</p>
          <p class="text-sm text-slate-500">Productores activos</p>
        </div>
        <div class="glass rounded-2xl p-6 text-center scroll-animate">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-amber-500 to-orange-500 flex items-center justify-center mx-auto mb-3 shadow-lg shadow-amber-200"><i class="fas fa-paw text-white"></i></div>
          <p class="text-lg font-bold text-slate-900"><span class="counter" data-target="14">0</span></p>
          <p class="text-sm text-slate-500">Especies soportadas</p>
        </div>
        <div class="glass rounded-2xl p-6 text-center scroll-animate">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center mx-auto mb-3 shadow-lg shadow-purple-200"><i class="fas fa-cloud text-white"></i></div>
          <p class="text-lg font-bold text-slate-900"><span class="counter" data-target="100">0</span>%</p>
          <p class="text-sm text-slate-500">En la nube</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="py-24 sm:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="scroll-animate">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-50 text-brand-700 text-xs font-semibold mb-6">Nacido en los Andes</div>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 text-balance mb-6 leading-tight tracking-tight">Para el productor <span class="text-brand-600">altoandino</span></h2>
          <p class="text-slate-500 leading-relaxed mb-4 text-lg">AGROVELAS nace en Cusco con la mision de llevar tecnologia accesible al productor ganadero. Sabemos que la trazabilidad, el control sanitario y la gestion financiera son claves para la competitividad del sector.</p>
          <p class="text-slate-500 leading-relaxed mb-8">Creamos una plataforma que funciona con Google Sheets — sin servidores costosos, sin infraestructura compleja. Solo necesitas un navegador.</p>
          <div class="flex flex-wrap gap-4">
            <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-brand-50 text-sm text-brand-700 font-medium"><i class="fas fa-check-circle text-brand-600"></i> Codigo abierto</div>
            <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-50 text-sm text-blue-700 font-medium"><i class="fas fa-check-circle text-blue-600"></i> Datos en tu poder</div>
            <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-emerald-50 text-sm text-emerald-700 font-medium"><i class="fas fa-check-circle text-emerald-600"></i> Sin mensualidades</div>
          </div>
        </div>
        <div class="relative scroll-animate">
          <div class="absolute -inset-4 bg-gradient-to-r from-brand-500/20 to-emerald-400/20 rounded-[2.5rem] blur-2xl"></div>
          <div class="relative overflow-hidden rounded-2xl shadow-2xl border border-slate-200">
            <div class="aspect-[4/3] bg-gradient-to-br from-brand-800 via-emerald-700 to-brand-600 flex items-center justify-center p-8">
              <div class="text-center text-white">
                <div class="w-16 h-16 rounded-2xl bg-white/20 backdrop-blur-sm flex items-center justify-center mx-auto mb-4"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg></div>
                <p class="text-2xl font-bold mb-2">Cusco, Peru</p>
                <p class="text-white/70 text-sm">Corazon de los Andes</p>
                <div class="flex justify-center gap-3 mt-6">
                  <div class="w-2 h-2 rounded-full bg-white/40"></div>
                  <div class="w-2 h-2 rounded-full bg-white/60"></div>
                  <div class="w-2 h-2 rounded-full bg-white/40"></div>
                </div>
              </div>
            </div>
          </div>
          <div class="absolute -bottom-4 -right-4 w-24 h-24 rounded-2xl bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center shadow-xl shadow-amber-200/50"><i class="fas fa-mountain text-white text-2xl"></i></div>
        </div>
      </div>
    </div>
  </section>

  <!-- MODULES -->
  <section id="modulos" class="py-24 sm:py-32 relative overflow-hidden" style="background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-20 right-0 w-64 h-64 bg-brand-200/30 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 left-0 w-80 h-80 bg-blue-200/20 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16 scroll-animate">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-50 text-brand-700 text-xs font-semibold mb-6">Funcionalidades</div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mt-3 text-balance leading-tight tracking-tight">Todo lo que necesitas <span class="text-brand-600">en un solo lugar</span></h2>
        <p class="text-slate-500 mt-4 text-lg">22 modulos integrados que cubren cada aspecto de la produccion ganadera altoandina.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        <div class="group rounded-2xl p-6 bg-white border border-slate-200 hover:border-brand-200 hover:shadow-xl hover:shadow-brand-200/20 transition-all duration-300 scroll-animate" style="--delay:0.03s">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-brand-500 to-emerald-500 flex items-center justify-center mb-4 shadow-lg shadow-brand-200/50 group-hover:scale-110 transition-transform"> <i class="fas fa-paw text-white"></i></div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Registro de Animales</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Ficha completa con datos fenotipicos, geneticos, genealogia y codigo QR para trazabilidad total.</p>
        </div>
        <div class="group rounded-2xl p-6 bg-white border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-200/20 transition-all duration-300 scroll-animate" style="--delay:0.06s">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center mb-4 shadow-lg shadow-blue-200/50 group-hover:scale-110 transition-transform"> <i class="fas fa-syringe text-white"></i></div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Sanidad y Alertas</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Calendario de vacunacion, tratamientos, desparasitaciones y alertas para animales en seguimiento.</p>
        </div>
        <div class="group rounded-2xl p-6 bg-white border border-slate-200 hover:border-purple-200 hover:shadow-xl hover:shadow-purple-200/20 transition-all duration-300 scroll-animate" style="--delay:0.09s">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-purple-600 flex items-center justify-center mb-4 shadow-lg shadow-purple-200/50 group-hover:scale-110 transition-transform"> <i class="fas fa-dna text-white"></i></div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Reproduccion</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Control de empadre, gestacion y partos. Calculo automatico de fechas probables de parto.</p>
        </div>
        <div class="group rounded-2xl p-6 bg-white border border-slate-200 hover:border-amber-200 hover:shadow-xl hover:shadow-amber-200/20 transition-all duration-300 scroll-animate" style="--delay:0.12s">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-amber-500 to-orange-500 flex items-center justify-center mb-4 shadow-lg shadow-amber-200/50 group-hover:scale-110 transition-transform"> <i class="fas fa-satellite-dish text-white"></i></div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Mapa IoT y GPS</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Geolocalizacion en tiempo real con collares GPS y sensores LoRa. Visualiza todo en un mapa.</p>
        </div>
        <div class="group rounded-2xl p-6 bg-white border border-slate-200 hover:border-emerald-200 hover:shadow-xl hover:shadow-emerald-200/20 transition-all duration-300 scroll-animate" style="--delay:0.15s">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-500 to-teal-500 flex items-center justify-center mb-4 shadow-lg shadow-emerald-200/50 group-hover:scale-110 transition-transform"> <i class="fas fa-coins text-white"></i></div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Contabilidad Ganadera</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Control de ingresos y egresos, balance general, comprobantes vinculados a animales y esquila.</p>
        </div>
        <div class="group rounded-2xl p-6 bg-white border border-slate-200 hover:border-rose-200 hover:shadow-xl hover:shadow-rose-200/20 transition-all duration-300 scroll-animate" style="--delay:0.18s">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-rose-500 to-pink-500 flex items-center justify-center mb-4 shadow-lg shadow-rose-200/50 group-hover:scale-110 transition-transform"> <i class="fas fa-user-md text-white"></i></div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Zootecnistas y Citas</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Directorio de especialistas, calificaciones y agenda de citas para conectar productores con veterinarios.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-24 sm:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16 scroll-animate">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-50 text-brand-700 text-xs font-semibold mb-6">Proceso</div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 text-balance leading-tight tracking-tight">Empieza en <span class="text-brand-600">3 pasos</span></h2>
      </div>

      <div class="grid md:grid-cols-3 gap-12 relative">
        <div class="text-center scroll-animate">
          <div class="relative mb-6 inline-block">
            <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-brand-500 to-emerald-500 text-white flex items-center justify-center mx-auto text-2xl font-bold shadow-xl shadow-brand-200/50">1</div>
