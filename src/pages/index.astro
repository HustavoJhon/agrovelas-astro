<style>
  /* --- STATS --- */
  .stats-orb { position:absolute;border-radius:50%;filter:blur(80px);opacity:0.6;animation:statsFloat 8s ease-in-out infinite;pointer-events:none; }
  @keyframes statsFloat { 0%,100% { transform:translateY(0) scale(1); } 50% { transform:translateY(-20px) scale(1.08); } }
  .stat-card { border-radius:1.25rem;padding:2rem 1.5rem;text-align:center;background:rgba(255,255,255,0.85);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.3);transition:all 0.3s ease;opacity:0;transform:translateY(24px);animation:statFadeIn 0.5s ease forwards; }
  .stat-card:nth-child(1) { animation-delay:0.05s; }
  .stat-card:nth-child(2) { animation-delay:0.15s; }
  .stat-card:nth-child(3) { animation-delay:0.25s; }
  .stat-card:nth-child(4) { animation-delay:0.35s; }
  .stat-card:hover { transform:translateY(-4px) scale(1.02);background:white;box-shadow:0 20px 25px -5px rgba(0,0,0,0.08); }
  @keyframes statFadeIn { to { opacity:1;transform:translateY(0); } }
  .stat-card-icon { width:3rem;height:3rem;border-radius:1rem;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem; }
  .stat-card-number { font-size:2rem;font-weight:800;color:#0f172a;margin:0 0 0.25rem;letter-spacing:-0.025em;line-height:1; }
  .stat-card-label { font-size:0.9375rem;font-weight:600;color:#0f172a;margin:0 0 0.25rem; }
  .stat-card-desc { font-size:0.8125rem;color:#94a3b8;margin:0; }

  /* --- MOBILE NAV --- */
  @media (max-width:767px) {
    #navbar { background:rgba(2,44,34,0.85);backdrop-filter:blur(12px);border-bottom:1px solid rgba(255,255,255,0.06); }
    .md-flex { display:none !important; }
    .nav-btn-ghost { display:none; }
    .nav-inner { height:3.5rem; }
    .mobile-actions { width:100%;padding:0 1.5rem; }
  }

  /* --- HERO --- */
  .hero-orb { position: absolute; border-radius: 50%; filter: blur(100px); opacity: 0.4; animation: orbFloat 8s ease-in-out infinite; }
  @keyframes orbFloat { 0%,100% { transform: translateY(0) scale(1); } 33% { transform: translateY(-30px) scale(1.05); } 66% { transform: translateY(15px) scale(0.95); } }

  .scroll-animate { opacity: 0; transform: translateY(32px); transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  .scroll-animate.visible { opacity: 1; transform: translateY(0); }

  .faq-item { border: 1px solid #e2e8f0; border-radius: 0.75rem; overflow: hidden; transition: border-color 0.2s ease; }
  .faq-item:hover { border-color: #cbd5e1; }
  .faq-question { width: 100%; display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.25rem; background: white; border: none; cursor: pointer; font-size: 0.9375rem; font-weight: 600; color: #0f172a; text-align: left; gap: 1rem; }
  .faq-question:hover { background: #f8fafc; }
  .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.3s ease, padding 0.3s ease; padding: 0 1.25rem; }
  .faq-answer.open { max-height: 300px; padding: 0 1.25rem 1.25rem; }
  .faq-item.open .faq-question i { transform: rotate(180deg); }
</style>

<script is:inline>
  function toggleFAQ(b) { var i=b.closest('.faq-item'),a=i.querySelector('.faq-answer'),o=i.classList.contains('open'); document.querySelectorAll('.faq-item.open').forEach(function(e){e.classList.remove('open');e.querySelector('.faq-answer').classList.remove('open')}); i.classList.toggle('open',!o); a.classList.toggle('open',!o); }
  function animateCounters(){ document.querySelectorAll('.counter').forEach(function(e){ var t=parseInt(e.getAttribute('data-target')),c=0,s=Math.ceil(t/40),x=setInterval(function(){c+=s;if(c>=t){c=t;clearInterval(x)}e.textContent=c},30)}) }
  function reveal(){ document.querySelectorAll('.scroll-animate:not(.visible)').forEach(function(e){ if(e.getBoundingClientRect().top<window.innerHeight-80) e.classList.add('visible') }) }
  document.addEventListener('DOMContentLoaded',function(){ reveal(); var s=document.querySelector('#stats'),ob; if(s){ob=new IntersectionObserver(function(e){e.forEach(function(ee){if(ee.isIntersecting){animateCounters();ob.disconnect()}})},{threshold:0.3});ob.observe(s)} window.addEventListener('scroll',reveal) });
  var nav=document.getElementById('navbar'); if(nav){ var ticking=false; window.addEventListener('scroll',function(){ if(!ticking){requestAnimationFrame(function(){nav.classList.toggle('scrolled',window.scrollY>20);ticking=false});ticking=true} }); }
</script>
