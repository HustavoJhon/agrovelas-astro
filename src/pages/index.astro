---
import Layout from '../layouts/Layout.astro';
import { getSession } from '../lib/auth';

const session = getSession(Astro.cookies);
if (session) return Astro.redirect('/dashboard');
---

<Layout title="AGROVELAS - Sistema de Gestion Ganadera Inteligente">
  <nav class="fixed top-0 inset-x-0 z-50 transition-all duration-300" id="navbar">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-3 no-underline">
          <div class="w-9 h-9 bg-brand-600 rounded-xl flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <span class="text-lg font-bold text-white tracking-tight">AGROVELAS</span>
        </a>
        <div class="hidden md:flex items-center gap-6">
          <a href="/acerca" class="text-sm text-white/70 hover:text-white transition-colors no-underline">Nosotros</a>
          <a href="#modulos" class="text-sm text-white/70 hover:text-white transition-colors no-underline">Modulos</a>
          <a href="#faq" class="text-sm text-white/70 hover:text-white transition-colors no-underline">FAQ</a>
        </div>
        <div class="flex items-center gap-3">
          <a href="/login" class="btn btn-sm bg-white text-brand-700 hover:bg-brand-50 no-underline">Ingresar</a>
          <a href="/registro" class="hidden sm:inline-flex btn btn-sm border border-white/30 text-white hover:bg-white/10 no-underline">Crear Cuenta</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center overflow-hidden" style="background: linear-gradient(160deg, #022c22 0%, #064e3b 30%, #065f46 60%, #047857 100%);">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-brand-400/10 blur-[120px]"></div>
      <div class="absolute -bottom-32 -left-32 w-[500px] h-[500px] rounded-full bg-emerald-300/10 blur-[100px]"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 md:py-40 w-full">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="anim-fade-up" style="animation-delay: 0.1s">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/20 text-white/80 text-xs font-medium mb-8">
            <span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-brand-400"></span></span>
            Hecho en Cusco &mdash; Peru
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-[1.08] text-balance mb-6">
            Gestion ganadera <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-300 to-emerald-200">inteligente</span> para el campo peruano
          </h1>
          <p class="text-lg text-brand-100/80 leading-relaxed mb-10 max-w-lg">
            Digitaliza el control de tu ganado: sanidad, reproduccion, trazabilidad, esquila, finanzas y geolocalizacion IoT en una sola plataforma. Diseñado para productores altoandinos.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/registro" class="btn btn-primary btn-lg no-underline shadow-xl shadow-brand-900/30">
              Comenzar Gratis
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#modulos" class="btn btn-lg border border-white/20 text-white hover:bg-white/10 no-underline">Ver Modulos</a>
          </div>

          <div class="flex items-center gap-6 mt-12 pt-8 border-t border-white/10">
            <div class="flex -space-x-2">
              <div class="w-9 h-9 rounded-full border-2 border-emerald-800 bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center text-white text-[10px] font-bold">JM</div>
              <div class="w-9 h-9 rounded-full border-2 border-emerald-800 bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center text-white text-[10px] font-bold">RV</div>
              <div class="w-9 h-9 rounded-full border-2 border-emerald-800 bg-gradient-to-br from-violet-400 to-violet-600 flex items-center justify-center text-white text-[10px] font-bold">AL</div>
              <div class="w-9 h-9 rounded-full border-2 border-emerald-800 bg-gradient-to-br from-rose-400 to-rose-600 flex items-center justify-center text-white text-[10px] font-bold">+</div>
            </div>
            <div>
              <p class="text-sm font-semibold text-white">+120 productores</p>
              <p class="text-xs text-brand-200/60">confian en AGROVELAS</p>
            </div>
          </div>
        </div>

        <div class="hidden lg:block anim-slide-right" style="animation-delay: 0.3s">
          <div class="relative">
            <div class="absolute -inset-4 bg-gradient-to-r from-brand-500/20 to-emerald-400/20 rounded-3xl blur-2xl"></div>
            <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-brand-900/30">
              <img src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=800&q=80&auto=format&fit=crop" alt="Paisaje andino" class="w-full h-[520px] object-cover" loading="eager" />
              <div class="absolute inset-0 bg-gradient-to-t from-emerald-900/80 via-emerald-900/10 to-transparent"></div>

              <div class="absolute top-4 right-4 glass-dark rounded-xl p-4 text-white text-center min-w-[120px]">
                <p class="text-2xl font-bold">22</p>
                <p class="text-[10px] text-white/70 mt-0.5">Modulos integrados</p>
              </div>

              <div class="absolute bottom-4 left-4 right-4 grid grid-cols-3 gap-2">
                <div class="glass-dark rounded-xl py-3 px-2 text-center">
                  <p class="text-lg font-bold text-white">IoT</p>
                  <p class="text-[10px] text-white/60">GPS tiempo real</p>
                </div>
                <div class="glass-dark rounded-xl py-3 px-2 text-center">
                  <p class="text-lg font-bold text-white">QR</p>
                  <p class="text-[10px] text-white/60">Trazabilidad</p>
                </div>
                <div class="glass-dark rounded-xl py-3 px-2 text-center">
                  <p class="text-lg font-bold text-white">S/</p>
                  <p class="text-[10px] text-white/60">Finanzas</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 inset-x-0 flex justify-center z-10">
      <a href="#stats" class="text-white/40 hover:text-white/70 transition-colors">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
      </a>
    </div>
  </section>

  <!-- STATS COUNTERS -->
  <section id="stats" class="py-16 bg-white border-y border-slate-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center scroll-animate">
          <p class="text-4xl font-extrabold text-brand-600"><span class="counter" data-target="22">0</span></p>
          <p class="text-sm text-slate-500 mt-1 font-medium">Modulos funcionales</p>
          <p class="text-xs text-slate-400 mt-0.5">Gestion integral del predio</p>
        </div>
        <div class="text-center scroll-animate">
          <p class="text-4xl font-extrabold text-blue-600"><span class="counter" data-target="120">0</span>+</p>
          <p class="text-sm text-slate-500 mt-1 font-medium">Productores activos</p>
          <p class="text-xs text-slate-400 mt-0.5">En toda la region Cusco</p>
        </div>
        <div class="text-center scroll-animate">
          <p class="text-4xl font-extrabold text-amber-600"><span class="counter" data-target="14">0</span></p>
          <p class="text-sm text-slate-500 mt-1 font-medium">Especies soportadas</p>
          <p class="text-xs text-slate-400 mt-0.5">Alpacas, llamas, ovinos y mas</p>
        </div>
        <div class="text-center scroll-animate">
          <p class="text-4xl font-extrabold text-purple-600"><span class="counter" data-target="100">0</span>%</p>
          <p class="text-sm text-slate-500 mt-1 font-medium">En la nube</p>
          <p class="text-xs text-slate-400 mt-0.5">Accesible desde cualquier lugar</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT / STORY -->
  <section class="py-24 sm:py-32 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="scroll-animate">
          <div class="text-xs font-semibold text-brand-600 uppercase tracking-[0.15em] mb-3">Nuestra Historia</div>
          <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 text-balance mb-6">Nacido en los Andes, para los Andes</h2>
          <p class="text-slate-500 leading-relaxed mb-4">AGROVELAS nace en Cusco, Peru, con la mision de llevar tecnologia accesible al productor ganadero altoandino. Sabemos que la trazabilidad, el control sanitario y la gestion financiera son claves para la competitividad del sector.</p>
          <p class="text-slate-500 leading-relaxed mb-6">Por eso creamos una plataforma que funciona con Google Sheets &mdash; sin servidores costosos, sin infraestructura compleja. Solo necesitas un navegador y conexion a internet.</p>
          <div class="flex flex-wrap gap-6">
            <div class="flex items-center gap-2 text-sm text-slate-600"><i class="fas fa-check-circle text-brand-600"></i> Codigo abierto</div>
            <div class="flex items-center gap-2 text-sm text-slate-600"><i class="fas fa-check-circle text-brand-600"></i> Datos en tu poder</div>
            <div class="flex items-center gap-2 text-sm text-slate-600"><i class="fas fa-check-circle text-brand-600"></i> Sin mensualidades</div>
          </div>
        </div>
        <div class="relative scroll-animate">
          <div class="absolute -inset-3 bg-gradient-to-r from-brand-500/10 to-emerald-400/10 rounded-3xl blur-xl"></div>
          <div class="relative rounded-2xl overflow-hidden shadow-xl">
            <img src="https://images.unsplash.com/photo-1516307365426-bea591f05011?w=800&q=80&auto=format&fit=crop" alt="Cusco - Peru" class="w-full h-80 object-cover" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            <div class="absolute bottom-4 left-4 right-4">
              <p class="text-white text-sm font-semibold">Cusco, Peru</p>
              <p class="text-white/60 text-xs">Capital historica del Peru</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MODULES -->
  <section id="modulos" class="py-24 sm:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <div class="text-xs font-semibold text-brand-600 uppercase tracking-[0.15em]">Modulos</div>
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mt-3 text-balance">Todo lo que necesitas para gestionar tu ganado</h2>
        <p class="text-slate-500 mt-4 text-balance">22 modulos integrados que cubren cada aspecto de la produccion ganadera altoandina.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="card-interactive p-6 group scroll-animate">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-brand-50 flex items-center justify-center group-hover:bg-brand-100 transition-colors shrink-0">
              <svg class="w-6 h-6 text-brand-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div class="rounded-lg overflow-hidden flex-1 h-20">
              <img src="https://images.unsplash.com/photo-1559563458-527698bf5295?w=200&q=60&auto=format&fit=crop" alt="Animales" class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Registro de Animales</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Ficha completa con datos fenotipicos, geneticos, genealogia, fotos y codigo QR para trazabilidad total de cada animal.</p>
        </div>

        <div class="card-interactive p-6 group scroll-animate">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center group-hover:bg-blue-100 transition-colors shrink-0">
              <svg class="w-6 h-6 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <div class="rounded-lg overflow-hidden flex-1 h-20">
              <img src="https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=200&q=60&auto=format&fit=crop" alt="Sanidad" class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Sanidad y Alertas</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Calendario de vacunacion, registro de tratamientos, desparasitaciones y alertas inteligentes para animales en seguimiento.</p>
        </div>

        <div class="card-interactive p-6 group scroll-animate">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-purple-50 flex items-center justify-center group-hover:bg-purple-100 transition-colors shrink-0">
              <svg class="w-6 h-6 text-purple-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <div class="rounded-lg overflow-hidden flex-1 h-20">
              <img src="https://images.unsplash.com/photo-1516307365426-bea591f05011?w=200&q=60&auto=format&fit=crop" alt="Reproduccion" class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Reproduccion</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Control de empadre, gestacion y partos. Calculo automatico de fechas probables de parto segun especie.</p>
        </div>

        <div class="card-interactive p-6 group scroll-animate">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-amber-50 flex items-center justify-center group-hover:bg-amber-100 transition-colors shrink-0">
              <svg class="w-6 h-6 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="rounded-lg overflow-hidden flex-1 h-20">
              <img src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?w=200&q=60&auto=format&fit=crop" alt="IoT" class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Mapa IoT y GPS</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Geolocalizacion en tiempo real de animales con collares GPS y sensores LoRa. Visualiza todo en un mapa interactivo.</p>
        </div>

        <div class="card-interactive p-6 group scroll-animate">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center group-hover:bg-emerald-100 transition-colors shrink-0">
              <svg class="w-6 h-6 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <div class="rounded-lg overflow-hidden flex-1 h-20">
              <img src="https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?w=200&q=60&auto=format&fit=crop" alt="Finanzas" class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Contabilidad Ganadera</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Control de ingresos y egresos, balance general, registro de comprobantes. Vinculado a animales y esquila.</p>
        </div>

        <div class="card-interactive p-6 group scroll-animate">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-rose-50 flex items-center justify-center group-hover:bg-rose-100 transition-colors shrink-0">
              <svg class="w-6 h-6 text-rose-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div class="rounded-lg overflow-hidden flex-1 h-20">
              <img src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=200&q=60&auto=format&fit=crop" alt="Zootecnistas" class="w-full h-full object-cover" loading="lazy" />
            </div>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Zootecnistas y Citas</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Directorio de especialistas, calificaciones, agenda de citas y horarios para conectar productores con veterinarios.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-24 sm:py-32 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <div class="text-xs font-semibold text-brand-600 uppercase tracking-[0.15em]">Proceso</div>
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mt-3 text-balance">Como empezar en 3 pasos</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
        <div class="text-center scroll-animate">
          <div class="relative mb-6 inline-block">
            <div class="w-20 h-20 rounded-2xl bg-brand-600 text-white flex items-center justify-center mx-auto text-2xl font-bold shadow-lg shadow-brand-200">1</div>
            <div class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-amber-400 flex items-center justify-center text-white text-[10px] font-bold"><i class="fas fa-user-plus"></i></div>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-3">Crea tu cuenta</h3>
          <p class="text-sm text-slate-500">Registrate gratis con tu nombre de usuario y contrasena. No necesitas tarjeta de credito ni contratos.</p>
          <div class="hidden md:block absolute top-10 left-[calc(100%-1rem)] w-12 h-0.5 bg-brand-200"></div>
        </div>
        <div class="text-center scroll-animate">
          <div class="relative mb-6 inline-block">
            <div class="w-20 h-20 rounded-2xl bg-brand-600 text-white flex items-center justify-center mx-auto text-2xl font-bold shadow-lg shadow-brand-200">2</div>
            <div class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-blue-400 flex items-center justify-center text-white text-[10px] font-bold"><i class="fas fa-paw"></i></div>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-3">Registra tus animales</h3>
          <p class="text-sm text-slate-500">Agrega tu ganado con datos completos: especie, raza, genealogia, sanidad y mas desde el panel de control.</p>
          <div class="hidden md:block absolute top-10 left-[calc(100%-1rem)] w-12 h-0.5 bg-brand-200"></div>
        </div>
        <div class="text-center scroll-animate">
          <div class="relative mb-6 inline-block">
            <div class="w-20 h-20 rounded-2xl bg-brand-600 text-white flex items-center justify-center mx-auto text-2xl font-bold shadow-lg shadow-brand-200">3</div>
            <div class="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-purple-400 flex items-center justify-center text-white text-[10px] font-bold"><i class="fas fa-chart-line"></i></div>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-3">Gestiona y controla</h3>
          <p class="text-sm text-slate-500">Monitorea sanidad, reproduccion, finanzas y ubicacion de todo tu ganado desde un solo tablero.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TECHNOLOGY -->
  <section class="py-24 sm:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <div class="text-xs font-semibold text-brand-600 uppercase tracking-[0.15em]">Tecnologia</div>
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mt-3 text-balance">Arquitectura moderna, operacion simple</h2>
        <p class="text-slate-500 mt-4 text-balance">Construido con tecnologias web modernas, desplegado en la nube, sincronizado con Google Sheets.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center scroll-animate">
          <div class="w-16 h-16 rounded-2xl bg-brand-50 flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-brand-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5"/><line x1="12" y1="22" x2="12" y2="15.5"/><polyline points="22 8.5 12 15.5 2 8.5"/></svg>
          </div>
