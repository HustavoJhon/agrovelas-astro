---
import Layout from '../layouts/Layout.astro';
import { getSession } from '../lib/auth';

const session = getSession(Astro.cookies);
if (session) return Astro.redirect('/dashboard');
---

<Layout title="AGROVELAS - Sistema de Gestion Ganadera Inteligente">
  <nav class="fixed top-0 inset-x-0 z-50 transition-all duration-300" id="navbar">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-3 no-underline">
          <div class="w-9 h-9 bg-brand-600 rounded-xl flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <span class="text-lg font-bold text-white tracking-tight">AGROVELAS</span>
        </a>
        <div class="hidden md:flex items-center gap-6">
          <a href="#features" class="text-sm text-white/70 hover:text-white transition-colors no-underline">Funcionalidades</a>
          <a href="#how-it-works" class="text-sm text-white/70 hover:text-white transition-colors no-underline">Como Funciona</a>
          <a href="/acerca" class="text-sm text-white/70 hover:text-white transition-colors no-underline">Acerca de</a>
        </div>
        <div class="flex items-center gap-3">
          <a href="/login" class="btn btn-sm bg-white text-brand-700 hover:bg-brand-50 no-underline">Iniciar Sesion</a>
          <a href="/registro" class="hidden sm:inline-flex btn btn-sm border border-white/30 text-white hover:bg-white/10 no-underline">Registrarse</a>
        </div>
      </div>
    </div>
  </nav>

  <section class="relative min-h-screen flex items-center overflow-hidden" style="background: linear-gradient(160deg, #022c22 0%, #064e3b 30%, #065f46 60%, #047857 100%);">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-brand-400/10 blur-[120px]"></div>
      <div class="absolute -bottom-32 -left-32 w-[500px] h-[500px] rounded-full bg-emerald-300/10 blur-[100px]"></div>
      <div class="absolute top-1/3 left-1/4 w-[300px] h-[300px] rounded-full bg-brand-500/5 blur-[80px]"></div>
      <svg class="absolute bottom-0 inset-x-0" viewBox="0 0 1440 120" preserveAspectRatio="none"><path d="M0 60C240 120 480 0 720 30s480-30 720 0v90H0V60z" fill="#f8fafc" opacity="0.06"/></svg>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 md:py-40">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="anim-fade-up" style="animation-delay: 0.1s">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/20 text-white/80 text-xs font-medium mb-8">
            <span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-brand-400"></span></span>
            Plataforma de Gestion Ganadera v2.0
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-[1.08] text-balance mb-6">
            Gestion ganadera <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-300 to-emerald-200">inteligente</span> para el campo peruano
          </h1>
          <p class="text-lg text-brand-100/80 leading-relaxed mb-10 max-w-lg">
            Diseñado para productores altoandinos. Digitaliza el control de tu ganado: sanidad, reproduccion, trazabilidad, esquila, finanzas y geolocalizacion IoT en una sola plataforma.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/registro" class="btn btn-primary btn-lg no-underline shadow-xl shadow-brand-900/30">
              Comenzar Gratis
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#features" class="btn btn-lg border border-white/20 text-white hover:bg-white/10 no-underline">
              Explorar Funcionalidades
            </a>
          </div>
        </div>

        <div class="hidden lg:block anim-slide-right" style="animation-delay: 0.3s">
          <div class="relative">
            <div class="glass-dark rounded-2xl p-8 space-y-5">
              <div class="grid grid-cols-2 gap-4">
                <div class="bg-white/10 rounded-xl p-5 text-center">
                  <p class="text-3xl font-bold text-white">22</p>
                  <p class="text-xs text-brand-200/70 mt-1">Modulos integrados</p>
                </div>
                <div class="bg-white/10 rounded-xl p-5 text-center">
                  <p class="text-3xl font-bold text-white">IoT</p>
                  <p class="text-xs text-brand-200/70 mt-1">GPS en tiempo real</p>
                </div>
                <div class="bg-white/10 rounded-xl p-5 text-center">
                  <p class="text-3xl font-bold text-white">QR</p>
                  <p class="text-xs text-brand-200/70 mt-1">Trazabilidad total</p>
                </div>
                <div class="bg-white/10 rounded-xl p-5 text-center">
                  <p class="text-3xl font-bold text-white">S/</p>
                  <p class="text-xs text-brand-200/70 mt-1">Control financiero</p>
                </div>
              </div>
              <div class="bg-white/5 rounded-xl p-4">
                <div class="flex items-center gap-3">
                  <div class="w-2 h-2 rounded-full bg-brand-400"></div>
                  <p class="text-sm text-white/60">Sincronizado con Google Sheets</p>
                </div>
                <div class="flex items-center gap-3 mt-2">
                  <div class="w-2 h-2 rounded-full bg-brand-400"></div>
                  <p class="text-sm text-white/60">Accesible sin conexion permanente</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 inset-x-0 flex justify-center z-10">
      <a href="#features" class="text-white/40 hover:text-white/70 transition-colors">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
      </a>
    </div>
  </section>

  <section id="features" class="py-24 sm:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <div class="text-xs font-semibold text-brand-600 uppercase tracking-[0.15em]">Funcionalidades</div>
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mt-3 text-balance">Todo lo que necesitas para gestionar tu ganado</h2>
        <p class="text-slate-500 mt-4 text-balance">Una plataforma integral diseñada especificamente para las necesidades del productor ganadero altoandino.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="card-interactive p-6 group">
          <div class="w-12 h-12 rounded-xl bg-brand-50 flex items-center justify-center mb-4 group-hover:bg-brand-100 transition-colors">
            <svg class="w-6 h-6 text-brand-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Registro de Animales</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Ficha completa con datos fenotipicos, geneticos, genealogia, fotos y codigo QR para trazabilidad total de cada animal.</p>
        </div>

        <div class="card-interactive p-6 group">
          <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center mb-4 group-hover:bg-blue-100 transition-colors">
            <svg class="w-6 h-6 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Sanidad y Alertas</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Calendario de vacunacion, registro de tratamientos, desparasitaciones y alertas inteligentes para animales en seguimiento.</p>
        </div>

        <div class="card-interactive p-6 group">
          <div class="w-12 h-12 rounded-xl bg-purple-50 flex items-center justify-center mb-4 group-hover:bg-purple-100 transition-colors">
            <svg class="w-6 h-6 text-purple-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Reproduccion</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Control de empadre, gestacion y partos. Calculo automatico de fechas probables de parto segun especie.</p>
        </div>

        <div class="card-interactive p-6 group">
          <div class="w-12 h-12 rounded-xl bg-amber-50 flex items-center justify-center mb-4 group-hover:bg-amber-100 transition-colors">
            <svg class="w-6 h-6 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Mapa IoT y GPS</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Geolocalizacion en tiempo real de animales con collares GPS y sensores LoRa. Visualiza todo en un mapa interactivo.</p>
        </div>

        <div class="card-interactive p-6 group">
          <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center mb-4 group-hover:bg-emerald-100 transition-colors">
            <svg class="w-6 h-6 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Contabilidad Ganadera</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Control de ingresos y egresos, balance general, registro de comprobantes. Vinculado a animales y esquila.</p>
        </div>

        <div class="card-interactive p-6 group">
          <div class="w-12 h-12 rounded-xl bg-rose-50 flex items-center justify-center mb-4 group-hover:bg-rose-100 transition-colors">
            <svg class="w-6 h-6 text-rose-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">Zootecnistas y Citas</h3>
          <p class="text-sm text-slate-500 leading-relaxed">Directorio de especialistas, calificaciones, agenda de citas y horarios para conectar productores con veterinarios.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="how-it-works" class="py-24 sm:py-32 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <div class="text-xs font-semibold text-brand-600 uppercase tracking-[0.15em]">Proceso</div>
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mt-3 text-balance">Como empezar en 3 pasos</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center relative">
          <div class="w-16 h-16 rounded-2xl bg-brand-600 text-white flex items-center justify-center mx-auto mb-6 text-xl font-bold shadow-lg shadow-brand-200">1</div>
          <h3 class="text-lg font-semibold text-slate-900 mb-3">Registrate</h3>
          <p class="text-sm text-slate-500">Crea tu cuenta gratuita en segundos. Solo necesitas un nombre de usuario y contraseña.</p>
          <div class="hidden md:block absolute top-8 left-[calc(100%-1rem)] w-12 h-0.5 bg-brand-200"></div>
        </div>
        <div class="text-center relative">
          <div class="w-16 h-16 rounded-2xl bg-brand-600 text-white flex items-center justify-center mx-auto mb-6 text-xl font-bold shadow-lg shadow-brand-200">2</div>
          <h3 class="text-lg font-semibold text-slate-900 mb-3">Registra tus animales</h3>
          <p class="text-sm text-slate-500">Agrega tu ganado con datos completos: especie, raza, genealogia, sanidad y mas desde el panel de control.</p>
          <div class="hidden md:block absolute top-8 left-[calc(100%-1rem)] w-12 h-0.5 bg-brand-200"></div>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl bg-brand-600 text-white flex items-center justify-center mx-auto mb-6 text-xl font-bold shadow-lg shadow-brand-200">3</div>
          <h3 class="text-lg font-semibold text-slate-900 mb-3">Gestiona y controla</h3>
          <p class="text-sm text-slate-500">Monitorea sanidad, reproduccion, finanzas y ubicacion de todo tu ganado desde un solo lugar.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 sm:py-32 bg-brand-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 left-10 w-72 h-72 bg-white rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-brand-400 rounded-full blur-3xl"></div>
    </div>
    <div class="relative z-10 max-w-3xl mx-auto text-center px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6 text-balance">Listo para transformar la gestion de tu ganado?</h2>
      <p class="text-brand-100/80 text-lg mb-10 max-w-xl mx-auto">Unete a los productores que ya confian en AGROVELAS para digitalizar y optimizar su produccion ganadera.</p>
      <a href="/registro" class="btn btn-primary btn-lg bg-white text-brand-700 hover:bg-brand-50 no-underline shadow-xl shadow-black/20">Crear cuenta gratuita</a>
    </div>
  </section>

  <footer class="bg-slate-900 text-slate-400 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-4 gap-8 mb-12">
        <div class="md:col-span-2">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 bg-brand-600 rounded-xl flex items-center justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/></svg>
            </div>
            <span class="text-lg font-bold text-white">AGROVELAS</span>
          </div>
          <p class="text-sm max-w-sm">Sistema de gestion ganadera inteligente para productores altoandinos. Desarrollado en Cusco, Peru.</p>
        </div>
        <div>
          <h4 class="text-xs font-semibold text-slate-300 uppercase tracking-wider mb-4">Producto</h4>
          <div class="space-y-2"><a href="#features" class="text-sm hover:text-white transition-colors no-underline block">Funcionalidades</a><a href="/acerca" class="text-sm hover:text-white transition-colors no-underline block">Acerca de</a></div>
        </div>
        <div>
          <h4 class="text-xs font-semibold text-slate-300 uppercase tracking-wider mb-4">Soporte</h4>
          <div class="space-y-2"><a href="mailto:contacto@agrovelas.pe" class="text-sm hover:text-white transition-colors no-underline block">Contacto</a></div>
        </div>
      </div>
      <div class="border-t border-slate-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-xs">&copy; 2026 AGROVELAS. Todos los derechos reservados.</p>
        <p class="text-xs">Hecho en Cusco, Peru</p>
      </div>
    </div>
  </footer>
</Layout>

<style>
  #navbar.scrolled { background: rgba(2,44,34,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.06); }
</style>

<script>
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const nav = document.getElementById('navbar');
    if (nav) {
      if (window.scrollY > 20) nav.classList.add('scrolled');
      else nav.classList.remove('scrolled');
    }
  });
</script>
