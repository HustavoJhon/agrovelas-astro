---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getSession } from '../lib/auth';
import { getDashboardData } from '../lib/sheets';

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect('/login');

let data: any = null;
let errorMsg = '';
try { data = await getDashboardData(); } catch (e: any) { errorMsg = e.message; }

let ingresos = 0, egresos = 0;
if (data?.contabilidad) {
  data.contabilidad.forEach((m: any) => {
    const mon = isNaN(parseFloat(m.monto)) ? 0 : parseFloat(m.monto);
    if (m.tipo === 'Ingreso') ingresos += mon; else egresos += mon;
  });
}

const agrup: Record<string, number> = {};
if (data?.animales) data.animales.forEach((a: any) => { agrup[a.especie] = (agrup[a.especie]||0)+1; });
const especies = Object.keys(agrup);
const cuentas = Object.values(agrup);
const balancePos = (ingresos - egresos) >= 0;
const balance = (ingresos - egresos).toFixed(0);
const tieneNotifs = (data?.notificaciones || []).length > 0;
const tieneActividades = (data?.actividades || []).length > 0;
const tieneChart = especies.length > 0;
const tieneFinanzas = ingresos > 0 || egresos > 0;
const totalAnimales = data?.totalAnimales || 0;
const totalAlertas = data?.alertas || 0;
const totalZoo = (data?.zootecnistas || []).length;
const totalNotifs = (data?.notificaciones || []).length;
const totalActs = (data?.actividades || []).length;
---

<DashboardLayout title="Dashboard" userName={session.nombre} rol={session.rol} currentPage="dashboard" chatData={{ animales: data?.animales, contabilidad: data?.contabilidad, alertasLista: data?.alertasLista, alertas: data?.alertas, zootecnistas: data?.zootecnistas, esquila: data?.esquila }}>
  {errorMsg ? (
    <div class="card p-5 bg-red-50 border-red-200 text-red-700 text-sm">
      <div class="flex items-center gap-2 font-medium mb-1"><i class="fas fa-exclamation-triangle"></i> Error de conexion</div>
      <p class="text-red-600/80">{errorMsg}</p>
    </div>
  ) : (
    <>
      <div class="page-header">
        <div>
          <h1>Panel de Control</h1>
          <p>Resumen general de la operacion ganadera</p>
        </div>
        <a href="/animales?nuevo=1" class="btn btn-primary no-underline"><i class="fas fa-plus text-xs"></i> Nuevo Animal</a>
      </div>

      <div class="stats-grid">
        <div class="stat-card-custom stat-emerald">
          <div class="stat-icon"><i class="fas fa-paw"></i></div>
          <div class="stat-body">
            <span class="stat-label">Animales</span>
            <span class="stat-value">{totalAnimales}</span>
            <span class="stat-desc">Total registrados</span>
          </div>
        </div>
        <div class="stat-card-custom stat-rose">
          <div class="stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
          <div class="stat-body">
            <span class="stat-label">Alertas</span>
            <span class="stat-value">{totalAlertas}</span>
            <span class="stat-desc">En seguimiento</span>
          </div>
        </div>
        <div class="stat-card-custom stat-blue">
          <div class="stat-icon"><i class="fas fa-user-md"></i></div>
          <div class="stat-body">
            <span class="stat-label">Especialistas</span>
            <span class="stat-value">{totalZoo}</span>
            <span class="stat-desc">Disponibles</span>
          </div>
        </div>
        <div class={"stat-card-custom " + (balancePos ? 'stat-emerald' : 'stat-rose')}>
          <div class="stat-icon"><i class="fas fa-coins"></i></div>
          <div class="stat-body">
            <span class="stat-label">Balance</span>
            <span class={"stat-value " + (balancePos ? '' : 'text-rose-600')}>{Number(balance) >= 0 ? 'S/ ' + balance : '-S/ ' + Math.abs(Number(balance))}</span>
            <span class="stat-desc">Ingresos - Egresos</span>
          </div>
        </div>
      </div>

      <div class="charts-grid">
        <div class="chart-card">
          <div class="chart-card-header">
            <div>
              <h3>Distribucion de Animales</h3>
              <p>Cantidad por especie</p>
            </div>
            {tieneChart ? <span class="badge-modern neutral">{totalAnimales} total</span> : ''}
          </div>
          <div class="chart-card-body">
            {tieneChart ? (
              <div class="chart-container"><canvas id="chartAnimals"></canvas></div>
            ) : (
              <div class="empty-chart">
                <div class="empty-icon"><i class="fas fa-chart-bar"></i></div>
                <p class="empty-title">Sin datos de animales</p>
                <p class="empty-desc">Registra tu primer animal para ver la distribucion por especie.</p>
                <a href="/animales?nuevo=1" class="btn btn-primary btn-sm no-underline"><i class="fas fa-plus text-xs"></i> Registrar Animal</a>
              </div>
            )}
          </div>
        </div>
        <div class="chart-card">
          <div class="chart-card-header">
            <div>
              <h3>Estado Financiero</h3>
              <p>Ingresos vs Egresos</p>
            </div>
            {tieneFinanzas ? <span class="badge-modern neutral">S/ {balance}</span> : ''}
          </div>
          <div class="chart-card-body">
            {tieneFinanzas ? (
              <div class="chart-container"><canvas id="chartFinance"></canvas></div>
            ) : (
              <div class="empty-chart">
                <div class="empty-icon"><i class="fas fa-chart-pie"></i></div>
                <p class="empty-title">Sin movimientos financieros</p>
                <p class="empty-desc">Agrega ingresos o egresos en la seccion de Contabilidad.</p>
                <a href="/contabilidad" class="btn btn-primary btn-sm no-underline"><i class="fas fa-plus text-xs"></i> Ir a Contabilidad</a>
              </div>
            )}
          </div>
        </div>
      </div>

      <div class="activity-grid">
        <div class="activity-card">
          <div class="activity-card-header">
            <div>
              <h3>Notificaciones recientes</h3>
              <p>Alertas y avisos del sistema</p>
            </div>
            <span class="badge-modern neutral">{totalNotifs}</span>
          </div>
          <div class="activity-card-body">
            {tieneNotifs ? (
              <div class="activity-list">
                {(data.notificaciones || []).slice(0, 5).map((n: any) => {
                  let ic = n.prioridad === 'Alta' || n.prioridad === 'Critica' ? 'urgent' : n.prioridad === 'Media' ? 'medium' : 'low';
                  return (
                    <div class={"notif-item " + ic}>
                      <div class="notif-dot"></div>
                      <div class="notif-content">
                        <p class="notif-text">{n.mensaje}</p>
                        <p class="notif-date">{n.fecha_generacion || ''}</p>
                      </div>
                    </div>
                  );
                })}
              </div>
            ) : (
              <div class="empty-small">
                <i class="fas fa-check-circle text-slate-300 text-lg"></i>
                <p>Sin notificaciones pendientes</p>
              </div>
            )}
          </div>
        </div>
        <div class="activity-card">
          <div class="activity-card-header">
            <div>
              <h3>Proximas actividades</h3>
              <p>Agenda y tareas programadas</p>
            </div>
            <span class="badge-modern neutral">{totalActs}</span>
          </div>
          <div class="activity-card-body">
            {tieneActividades ? (
              <div class="activity-list">
                {(data.actividades || []).slice(0, 5).map((a: any) => (
                  <div class="activity-item">
                    <div class="activity-icon"><i class="fas fa-calendar-day"></i></div>
                    <div class="activity-info">
                      <p class="activity-title">{a.titulo}</p>
                      <p class="activity-meta">{a.fecha}{a.hora ? ' ' + a.hora : ''}</p>
                    </div>
                    <span class="badge-modern neutral text-[10px]">{a.tipo}</span>
                  </div>
                ))}
              </div>
            ) : (
              <div class="empty-small">
                <i class="fas fa-calendar text-slate-300 text-lg"></i>
                <p>Sin actividades programadas</p>
              </div>
            )}
          </div>
        </div>
      </div>
    </>
  )}
</DashboardLayout>

<script>
  import { Chart } from 'chart.js';

  document.addEventListener('DOMContentLoaded', function() {
    initCharts();
  });

  function initCharts() {
    var especies = [];
    var cuentas = [];
    var ingresos = 0;
    var egresos = 0;

    try {
      var el = document.getElementById('chartData');
      if (el) {
        var d = JSON.parse(el.textContent);
        especies = d.especies || [];
        cuentas = d.cuentas || [];
        ingresos = d.ingresos || 0;
        egresos = d.egresos || 0;
      }
    } catch(e) {}

    var colors = ['#059669','#3b82f6','#f59e0b','#8b5cf6','#ef4444','#10b981','#ec4899'];

    var c1 = document.getElementById('chartAnimals');
    if (c1 && especies.length > 0) {
      new Chart(c1, {
        type: 'bar',
        data: { labels: especies, datasets: [{ data: cuentas, backgroundColor: colors.slice(0, especies.length), borderRadius: 8, borderSkipped: false }] },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#f1f5f9' } }, x: { grid: { display: false }, ticks: { font: { family: 'Inter, system-ui, sans-serif', size: 11 } } } } }
      });
    }

    var c2 = document.getElementById('chartFinance');
    if (c2 && (ingresos > 0 || egresos > 0)) {
      new Chart(c2, {
        type: 'doughnut',
        data: { labels: ['Ingresos','Egresos'], datasets: [{ data: [ingresos, egresos], backgroundColor: ['#059669','#ef4444'], borderWidth: 0 }] },
        options: { responsive: true, maintainAspectRatio: false, cutout: '70%', plugins: { legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true, pointStyleWidth: 10, font: { family: 'Inter, system-ui, sans-serif', size: 12 } } } } }
      });
    }
  }
</script>

<script type="application/json" id="chartData">{JSON.stringify({ especies, cuentas, ingresos, egresos })}</script>
