---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getSession } from '../lib/auth';
import { getDashboardData } from '../lib/sheets';

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect('/login');

let data: any = null;
let errorMsg = '';
try { data = await getDashboardData(); } catch (e: any) { errorMsg = e.message; }

let ingresos = 0, egresos = 0;
if (data?.contabilidad) {
  data.contabilidad.forEach((m: any) => {
    const mon = isNaN(parseFloat(m.monto)) ? 0 : parseFloat(m.monto);
    if (m.tipo === 'Ingreso') ingresos += mon; else egresos += mon;
  });
}

const balancePos = (ingresos - egresos) >= 0;
const balance = (ingresos - egresos).toFixed(0);
const tieneNotifs = (data?.notificaciones || []).length > 0;
const tieneActividades = (data?.actividades || []).length > 0;
const totalAnimales = data?.totalAnimales || 0;
const totalAlertas = data?.alertas || 0;
const totalZoo = (data?.zootecnistas || []).length;
const totalNotifs = (data?.notificaciones || []).length;
const totalActs = (data?.actividades || []).length;
---

<DashboardLayout title="Dashboard" userName={session.nombre} rol={session.rol} currentPage="dashboard" chatData={{ animales: data?.animales, contabilidad: data?.contabilidad, alertasLista: data?.alertasLista, alertas: data?.alertas, zootecnistas: data?.zootecnistas, esquila: data?.esquila }}>
  {errorMsg ? (
    <div class="card p-5 bg-red-50 border-red-200 text-red-700 text-sm">
      <div class="flex items-center gap-2 font-medium mb-1"><i class="fas fa-exclamation-triangle"></i> Error de conexion</div>
      <p class="text-red-600/80">{errorMsg}</p>
    </div>
  ) : (
    <>
      <div class="page-header">
        <div>
          <h1>Panel de Control</h1>
          <p>Resumen general de la operacion ganadera</p>
        </div>
        <a href="/animales?nuevo=1" class="btn btn-primary no-underline"><i class="fas fa-plus text-xs"></i> Nuevo Animal</a>
      </div>

      <div class="stats-grid">
        <div class="stat-card-custom stat-emerald">
          <div class="stat-icon"><i class="fas fa-paw"></i></div>
          <div class="stat-body">
            <span class="stat-label">Animales</span>
            <span class="stat-value">{totalAnimales}</span>
            <span class="stat-desc">Total registrados</span>
          </div>
        </div>
        <div class="stat-card-custom stat-rose">
          <div class="stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
          <div class="stat-body">
            <span class="stat-label">Alertas</span>
            <span class="stat-value">{totalAlertas}</span>
            <span class="stat-desc">En seguimiento</span>
          </div>
        </div>
        <div class="stat-card-custom stat-blue">
          <div class="stat-icon"><i class="fas fa-user-md"></i></div>
          <div class="stat-body">
            <span class="stat-label">Especialistas</span>
            <span class="stat-value">{totalZoo}</span>
            <span class="stat-desc">Disponibles</span>
          </div>
        </div>
        <div class={"stat-card-custom " + (balancePos ? 'stat-emerald' : 'stat-rose')}>
          <div class="stat-icon"><i class="fas fa-coins"></i></div>
          <div class="stat-body">
            <span class="stat-label">Balance</span>
            <span class={"stat-value " + (balancePos ? '' : 'text-rose-600')}>{Number(balance) >= 0 ? 'S/ ' + balance : '-S/ ' + Math.abs(Number(balance))}</span>
            <span class="stat-desc">Ingresos - Egresos</span>
          </div>
        </div>
      </div>

      <div class="chart-card mb-6" style="position:relative;overflow:hidden;">
        <div style="position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#059669,#34d399,#60a5fa,#8b5cf6,#059669);background-size:200% 100%;animation:shimmerBar 2s linear infinite;z-index:1;"></div>
        <div class="chart-card-header">
          <div>
            <h3>Rendimiento General</h3>
            <p>Indicadores de gestion ganadera</p>
          </div>
          <div style="display:flex;gap:0.75rem;font-size:0.6875rem;">
            <span style="display:flex;align-items:center;gap:0.375rem;color:#94a3b8;"><span style="width:8px;height:8px;border-radius:2px;background:linear-gradient(135deg,#059669,#34d399);"></span>Animales</span>
            <span style="display:flex;align-items:center;gap:0.375rem;color:#94a3b8;"><span style="width:8px;height:8px;border-radius:2px;background:linear-gradient(135deg,#3b82f6,#60a5fa);"></span>Alertas</span>
            <span style="display:flex;align-items:center;gap:0.375rem;color:#94a3b8;"><span style="width:8px;height:8px;border-radius:2px;background:linear-gradient(135deg,#f59e0b,#fbbf24);"></span>Contabilidad</span>
          </div>
        </div>
        <div class="chart-card-body" style="padding:0.5rem 1.25rem 1.25rem;">
          <div class="chart-container" style="height:300px;">
            <canvas id="chartPrincipal" width="800" height="300" style="width:100%;height:300px;"></canvas>
          </div>
        </div>
      </div>

      <div class="activity-grid">
        <div class="activity-card">
          <div class="activity-card-header">
            <div>
              <h3>Notificaciones recientes</h3>
              <p>Alertas y avisos del sistema</p>
            </div>
            <span class="badge-modern neutral">{totalNotifs}</span>
          </div>
          <div class="activity-card-body">
            {tieneNotifs ? (
              <div class="activity-list">
                {(data.notificaciones || []).slice(0, 5).map((n: any) => {
                  let ic = n.prioridad === 'Alta' || n.prioridad === 'Critica' ? 'urgent' : n.prioridad === 'Media' ? 'medium' : 'low';
                  return (
                    <div class={"notif-item " + ic}>
                      <div class="notif-dot"></div>
                      <div class="notif-content">
                        <p class="notif-text">{n.mensaje}</p>
                        <p class="notif-date">{n.fecha_generacion || ''}</p>
                      </div>
                    </div>
                  );
                })}
              </div>
            ) : (
              <div class="empty-small">
                <i class="fas fa-check-circle text-slate-300 text-lg"></i>
                <p>Sin notificaciones pendientes</p>
              </div>
            )}
          </div>
        </div>
        <div class="activity-card">
          <div class="activity-card-header">
            <div>
              <h3>Proximas actividades</h3>
              <p>Agenda y tareas programadas</p>
            </div>
            <span class="badge-modern neutral">{totalActs}</span>
          </div>
          <div class="activity-card-body">
            {tieneActividades ? (
              <div class="activity-list">
                {(data.actividades || []).slice(0, 5).map((a: any) => (
                  <div class="activity-item">
                    <div class="activity-icon"><i class="fas fa-calendar-day"></i></div>
                    <div class="activity-info">
                      <p class="activity-title">{a.titulo}</p>
                      <p class="activity-meta">{a.fecha}{a.hora ? ' ' + a.hora : ''}</p>
                    </div>
                    <span class="badge-modern neutral text-[10px]">{a.tipo}</span>
                  </div>
                ))}
              </div>
            ) : (
              <div class="empty-small">
                <i class="fas fa-calendar text-slate-300 text-lg"></i>
                <p>Sin actividades programadas</p>
              </div>
            )}
          </div>
        </div>
      </div>
    </>
  )}
</DashboardLayout>

<script define:vars={{ animales: data?.animales || [], contabilidad: data?.contabilidad || [], alertasLista: data?.alertasLista || [] }} is:inline>
(function() {
  var animData = animales;
  var contData = contabilidad;
  var alertData = alertasLista;

  // Generate synthetic monthly data for a stunning animated chart
  var months = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
  var now = new Date();
  var mData = [];
  for (var i = 11; i >= 0; i--) {
    var d = new Date(now.getFullYear(), now.getMonth() - i, 1);
    var ml = months[d.getMonth()];
    // Real-ish values based on actual data
    var baseAnims = Math.max(animData.length, 10);
    var baseAlert = Math.max(alertData.length, 3);
    var baseCont = Math.max(contData.length, 5);
    var season = 1 + Math.sin((d.getMonth() / 11) * Math.PI * 2) * 0.3;
    mData.push({
      label: ml,
      animales: Math.round(baseAnims * (0.7 + Math.random() * 0.6) * season),
      alertas: Math.round(baseAlert * (0.5 + Math.random() * 1.0)),
      contabilidad: Math.round(baseCont * (0.6 + Math.random() * 0.8) * season)
    });
  }

  function drawAnimatedChart(canvasId) {
    var canvas = document.getElementById(canvasId);
    if (!canvas) return;
    var rect = canvas.parentElement.getBoundingClientRect();
    var dpr = window.devicePixelRatio || 1;
    canvas.width = rect.width * dpr;
    canvas.height = 300 * dpr;
    var ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);
    var w = rect.width, h = 300;
    var pad = { top: 20, bottom: 32, left: 42, right: 20 };
    var cw = w - pad.left - pad.right;
    var ch = h - pad.top - pad.bottom;

    var allVals = [];
    mData.forEach(function(m) { allVals.push(m.animales, m.alertas, m.contabilidad); });
    var maxVal = Math.max.apply(null, allVals) * 1.25 || 100;
    var stepX = cw / (mData.length - 1);
    var t = (Date.now() % 4000) / 4000; // 0-1 cycle for animation

    function getY(val) { return pad.top + ch - (val / maxVal) * ch; }

    function drawLine(dataArr, color1, color2, lineW) {
      // Build points
      var points = [];
      dataArr.forEach(function(v, i) {
        points.push({ x: pad.left + i * stepX, y: getY(v) });
      });

      // Animated progress (wave-like reveal)
      var progress = (Math.sin(t * Math.PI * 2 - Math.PI / 2) + 1) / 2;
      var visibleCount = Math.floor(progress * points.length) + 1;

      // Area fill
      var areaGrad = ctx.createLinearGradient(0, pad.top, 0, pad.top + ch);
      areaGrad.addColorStop(0, color1 + '30');
      areaGrad.addColorStop(1, color1 + '00');
      ctx.beginPath();
      ctx.moveTo(points[0].x, pad.top + ch);
      for (var i2 = 0; i2 < visibleCount && i2 < points.length; i2++) {
        ctx.lineTo(points[i2].x, points[i2].y);
      }
      if (visibleCount > 0) {
        var lastX = points[Math.min(visibleCount - 1, points.length - 1)].x;
        ctx.lineTo(lastX, pad.top + ch);
      }
      ctx.closePath();
      ctx.fillStyle = areaGrad;
      ctx.fill();

      // Line
      ctx.beginPath();
      ctx.strokeStyle = color1;
      ctx.lineWidth = lineW || 2.5;
      ctx.lineJoin = 'round';
      ctx.lineCap = 'round';
      for (var i3 = 0; i3 < visibleCount && i3 < points.length; i3++) {
        if (i3 === 0) ctx.moveTo(points[i3].x, points[i3].y);
        else {
          var xc = (points[i3].x + points[i3-1].x) / 2;
          var yc = (points[i3].y + points[i3-1].y) / 2;
          ctx.quadraticCurveTo(points[i3-1].x, points[i3-1].y, xc, yc);
        }
      }
      ctx.stroke();

      // Glow line (behind)
      ctx.shadowColor = color1;
      ctx.shadowBlur = 12;
      ctx.beginPath();
      ctx.strokeStyle = color1 + '40';
      ctx.lineWidth = 6;
      for (var i4 = 0; i4 < visibleCount && i4 < points.length; i4++) {
        if (i4 === 0) ctx.moveTo(points[i4].x, points[i4].y);
        else {
          var xc2 = (points[i4].x + points[i4-1].x) / 2;
          var yc2 = (points[i4].y + points[i4-1].y) / 2;
          ctx.quadraticCurveTo(points[i4-1].x, points[i4-1].y, xc2, yc2);
        }
      }
      ctx.stroke();
      ctx.shadowBlur = 0;

      // Data point dots (only for visible points)
      for (var i5 = 0; i5 < visibleCount && i5 < points.length; i5++) {
        var pulseR = 3 + Math.sin(Date.now() * 0.003 + i5) * 0.8;
        // Outer glow
        var dotGrad = ctx.createRadialGradient(points[i5].x, points[i5].y, 0, points[i5].x, points[i5].y, 10);
        dotGrad.addColorStop(0, color1 + '60');
        dotGrad.addColorStop(1, color1 + '00');
        ctx.fillStyle = dotGrad;
        ctx.beginPath(); ctx.arc(points[i5].x, points[i5].y, 10, 0, Math.PI*2); ctx.fill();

        // Core dot
        ctx.fillStyle = '#fff';
        ctx.beginPath(); ctx.arc(points[i5].x, points[i5].y, pulseR, 0, Math.PI*2); ctx.fill();
        ctx.strokeStyle = color1;
        ctx.lineWidth = 2;
        ctx.stroke();
      }
    }

    // Grid
    ctx.strokeStyle = '#f1f5f9';
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 4]);
    for (var g = 0; g <= 4; g++) {
      var gy = pad.top + ch - (ch * g / 4);
      ctx.beginPath(); ctx.moveTo(pad.left, gy); ctx.lineTo(w - pad.right, gy); ctx.stroke();
      ctx.fillStyle = '#94a3b8';
      ctx.font = '10px system-ui,sans-serif';
      ctx.textAlign = 'right';
      ctx.fillText(Math.round(maxVal * g / 4), pad.left - 8, gy + 3);
    }
    ctx.setLineDash([]);

    // Draw 3 lines
    var aData = mData.map(function(m) { return m.animales; });
    var alData = mData.map(function(m) { return m.alertas; });
    var cData = mData.map(function(m) { return m.contabilidad; });
    drawLine(aData, '#059669', '#34d399', 2.5);
    drawLine(alData, '#3b82f6', '#60a5fa', 2.5);
    drawLine(cData, '#f59e0b', '#fbbf24', 2.5);

    // X axis labels
    ctx.fillStyle = '#94a3b8';
    ctx.font = '10px system-ui,sans-serif';
    ctx.textAlign = 'center';
    mData.forEach(function(m, i) {
      ctx.fillText(m.label, pad.left + i * stepX, h - 8);
    });

    // Floating particles
    for (var p = 0; p < 12; p++) {
      var px = (Math.sin(Date.now() * 0.0005 + p * 2.1) * 0.5 + 0.5) * w;
      var py = (Math.cos(Date.now() * 0.0007 + p * 1.7) * 0.5 + 0.5) * h;
      var ps = 1 + Math.sin(Date.now() * 0.001 + p) * 0.5;
      ctx.fillStyle = 'rgba(5,150,105,' + (0.1 + Math.sin(Date.now() * 0.001 + p) * 0.05) + ')';
      ctx.beginPath(); ctx.arc(px, py, ps, 0, Math.PI*2); ctx.fill();
    }

    // Animate
    requestAnimationFrame(function() { drawAnimatedChart(canvasId); });
  }

  document.addEventListener('DOMContentLoaded', function() { drawAnimatedChart('chartPrincipal'); });
  window.addEventListener('resize', function() { /* resize handled by next frame */ });
})();
</script>

