---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getSession } from '../lib/auth';
import { getDashboardData } from '../lib/sheets';

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect('/login');

let data: any = null;
let errorMsg = '';
try { data = await getDashboardData(); } catch (e: any) { errorMsg = e.message; }

let ingresos = 0, egresos = 0;
if (data?.contabilidad) {
  data.contabilidad.forEach((m: any) => {
    const mon = isNaN(parseFloat(m.monto)) ? 0 : parseFloat(m.monto);
    if (m.tipo === 'Ingreso') ingresos += mon; else egresos += mon;
  });
}

const agrup: Record<string, number> = {};
if (data?.animales) data.animales.forEach((a: any) => { agrup[a.especie] = (agrup[a.especie]||0)+1; });
const especies = Object.keys(agrup);
const cuentas = Object.values(agrup);
const balancePos = (ingresos - egresos) >= 0;
---

<DashboardLayout title="Dashboard" userName={session.nombre} rol={session.rol} currentPage="dashboard">
  {errorMsg ? (
    <div class="card p-4 bg-red-50 border-red-200 text-red-700 text-sm">
      <div class="flex items-center gap-2 font-medium mb-1"><i class="fas fa-exclamation-triangle"></i> Error de conexion</div>
      <p class="text-red-600/80">{errorMsg}</p>
    </div>
  ) : (
    <>
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
        <div>
          <h1 class="text-2xl font-bold text-slate-900">Panel de Control</h1>
          <p class="text-sm text-slate-500 mt-1">Resumen general de la operacion ganadera</p>
        </div>
        <a href="/animales?nuevo=1" class="btn btn-primary no-underline"><i class="fas fa-plus text-xs"></i> Nuevo Animal</a>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="grad-emerald text-white rounded-xl p-5 shadow-lg shadow-brand-200/30">
          <div class="flex items-center justify-between mb-3"><span class="stat-label">Animales</span><i class="fas fa-paw opacity-30 text-lg"></i></div>
          <p class="stat-value">{data.totalAnimales || 0}</p>
          <p class="text-xs opacity-70 mt-1">Total registrados</p>
        </div>
        <div class="grad-blue text-white rounded-xl p-5 shadow-lg shadow-blue-200/30">
          <div class="flex items-center justify-between mb-3"><span class="stat-label">Alertas</span><i class="fas fa-exclamation-triangle opacity-30 text-lg"></i></div>
          <p class="stat-value">{data.alertas}</p>
          <p class="text-xs opacity-70 mt-1">En seguimiento</p>
        </div>
        <div class="grad-amber text-white rounded-xl p-5 shadow-lg shadow-amber-200/30">
          <div class="flex items-center justify-between mb-3"><span class="stat-label">Especialistas</span><i class="fas fa-user-md opacity-30 text-lg"></i></div>
          <p class="stat-value">{(data.zootecnistas || []).length}</p>
          <p class="text-xs opacity-70 mt-1">Disponibles</p>
        </div>
        <div class={"rounded-xl p-5 shadow-lg text-white " + (balancePos ? 'grad-emerald shadow-brand-200/30' : 'grad-rose shadow-rose-200/30')}>
          <div class="flex items-center justify-between mb-3"><span class="stat-label">Balance</span><i class="fas fa-coins opacity-30 text-lg"></i></div>
          <p class="stat-value">S/ {(ingresos - egresos).toFixed(0)}</p>
          <p class="text-xs opacity-70 mt-1">Ingresos - Egresos</p>
        </div>
      </div>

      <div class="grid lg:grid-cols-3 gap-6 mb-8">
        <div class="lg:col-span-2 card p-6">
          <h3 class="text-base font-semibold text-slate-900 mb-1">Distribucion de Animales</h3>
          <p class="text-xs text-slate-400 mb-6">Cantidad por especie</p>
          <div style="height: 280px"><canvas id="chartAnimals"></canvas></div>
        </div>
        <div class="card p-6">
          <h3 class="text-base font-semibold text-slate-900 mb-1">Estado Financiero</h3>
          <p class="text-xs text-slate-400 mb-6">Ingresos vs Egresos</p>
          <div style="height: 280px"><canvas id="chartFinance"></canvas></div>
        </div>
      </div>

      <div class="grid lg:grid-cols-2 gap-6">
        <div class="card p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-base font-semibold text-slate-900">Notificaciones recientes</h3>
            <span class="badge badge-neutral">{(data.notificaciones || []).length}</span>
          </div>
          <div class="space-y-2">
            {(data.notificaciones || []).length === 0 ? (
              <div class="text-center py-8 text-slate-400 text-sm">Sin notificaciones pendientes</div>
            ) : (
              (data.notificaciones || []).slice(0, 5).map((n: any) => {
                let cls = 'notif-card default';
                if (n.prioridad === 'Alta' || n.prioridad === 'Critica') cls = 'notif-card urgent';
                else if (n.prioridad === 'Media') cls = 'notif-card medium';
                else if (n.prioridad === 'Baja') cls = 'notif-card low';
                return (
                  <div class={cls}>
                    <p class="text-sm text-slate-700">{n.mensaje}</p>
                    <p class="text-xs text-slate-400 mt-1">{n.fecha_generacion || ''}</p>
                  </div>
                );
              })
            )}
          </div>
        </div>
        <div class="card p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-base font-semibold text-slate-900">Proximas actividades</h3>
            <span class="badge badge-neutral">{(data.actividades || []).length}</span>
          </div>
          <div class="space-y-2">
            {(data.actividades || []).length === 0 ? (
              <div class="text-center py-8 text-slate-400 text-sm">Sin actividades programadas</div>
            ) : (
              (data.actividades || []).slice(0, 5).map((a: any) => (
                <div class="activity-item">
                  <div class="w-10 h-10 rounded-lg bg-brand-100 flex items-center justify-center shrink-0">
                    <i class="fas fa-calendar-day text-brand-600 text-sm"></i>
                  </div>
                  <div class="min-w-0">
                    <p class="text-sm font-medium text-slate-700 truncate">{a.titulo}</p>
                    <p class="text-xs text-slate-400">{a.fecha}{a.hora ? ' \u2022 ' + a.hora : ''}</p>
                  </div>
                </div>
              ))
            )}
          </div>
        </div>
      </div>
    </>
  )}
</DashboardLayout>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script define:vars={{ especies, cuentas, ingresos, egresos }}>
  (function() {
    var colors = ['#059669','#3b82f6','#f59e0b','#8b5cf6','#ef4444','#10b981','#ec4899'];
    if (typeof Chart !== 'undefined') {
      var c1 = document.getElementById('chartAnimals');
      if (c1 && especies.length > 0) {
        new Chart(c1, { type: 'bar', data: { labels: especies, datasets: [{ data: cuentas, backgroundColor: colors.slice(0, especies.length), borderRadius: 8, borderSkipped: false }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } } } });
      }
      var c2 = document.getElementById('chartFinance');
      if (c2) {
        new Chart(c2, { type: 'doughnut', data: { labels: ['Ingresos','Egresos'], datasets: [{ data: [ingresos||0, egresos||0], backgroundColor: ['#059669','#ef4444'], borderWidth: 0, borderRadius: 4 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true, pointStyleWidth: 8 } } } } });
      }
    } else {
      setTimeout(function(){ if(typeof Chart === 'undefined') window.location.reload(); }, 1500);
    }
  })();
</script>
