---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getSession } from '../lib/auth';
import { getDashboardData } from '../lib/sheets';

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect('/login');

let data: any = null;
let errorMsg = '';
try { data = await getDashboardData(); } catch (e: any) { errorMsg = e.message; }

let ingresos = 0, egresos = 0;
if (data?.contabilidad) {
  data.contabilidad.forEach((m: any) => {
    const mon = isNaN(parseFloat(m.monto)) ? 0 : parseFloat(m.monto);
    if (m.tipo === 'Ingreso') ingresos += mon; else egresos += mon;
  });
}

const balancePos = (ingresos - egresos) >= 0;
const balance = (ingresos - egresos).toFixed(0);
const tieneNotifs = (data?.notificaciones || []).length > 0;
const tieneActividades = (data?.actividades || []).length > 0;
const totalAnimales = data?.totalAnimales || 0;
const totalAlertas = data?.alertas || 0;
const totalZoo = (data?.zootecnistas || []).length;
const totalNotifs = (data?.notificaciones || []).length;
const totalActs = (data?.actividades || []).length;
---

<DashboardLayout title="Dashboard" userName={session.nombre} rol={session.rol} currentPage="dashboard" chatData={{ animales: data?.animales, contabilidad: data?.contabilidad, alertasLista: data?.alertasLista, alertas: data?.alertas, zootecnistas: data?.zootecnistas, esquila: data?.esquila }}>
  {errorMsg ? (
    <div class="card p-5 bg-red-50 border-red-200 text-red-700 text-sm">
      <div class="flex items-center gap-2 font-medium mb-1"><i class="fas fa-exclamation-triangle"></i> Error de conexion</div>
      <p class="text-red-600/80">{errorMsg}</p>
    </div>
  ) : (
    <>
      <div class="page-header">
        <div>
          <h1>Panel de Control</h1>
          <p>Resumen general de la operacion ganadera</p>
        </div>
        <a href="/animales?nuevo=1" class="btn btn-primary no-underline"><i class="fas fa-plus text-xs"></i> Nuevo Animal</a>
      </div>

      <div class="stats-grid">
        <div class="stat-card-custom stat-emerald">
          <div class="stat-icon"><i class="fas fa-paw"></i></div>
          <div class="stat-body">
            <span class="stat-label">Animales</span>
            <span class="stat-value">{totalAnimales}</span>
            <span class="stat-desc">Total registrados</span>
          </div>
        </div>
        <div class="stat-card-custom stat-rose">
          <div class="stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
          <div class="stat-body">
            <span class="stat-label">Alertas</span>
            <span class="stat-value">{totalAlertas}</span>
            <span class="stat-desc">En seguimiento</span>
          </div>
        </div>
        <div class="stat-card-custom stat-blue">
          <div class="stat-icon"><i class="fas fa-user-md"></i></div>
          <div class="stat-body">
            <span class="stat-label">Especialistas</span>
            <span class="stat-value">{totalZoo}</span>
            <span class="stat-desc">Disponibles</span>
          </div>
        </div>
        <div class={"stat-card-custom " + (balancePos ? 'stat-emerald' : 'stat-rose')}>
          <div class="stat-icon"><i class="fas fa-coins"></i></div>
          <div class="stat-body">
            <span class="stat-label">Balance</span>
            <span class={"stat-value " + (balancePos ? '' : 'text-rose-600')}>{Number(balance) >= 0 ? 'S/ ' + balance : '-S/ ' + Math.abs(Number(balance))}</span>
            <span class="stat-desc">Ingresos - Egresos</span>
          </div>
        </div>
      </div>

      <div class="charts-grid">
        <div class="chart-card">
          <div class="chart-card-header">
            <div>
              <h3>Distribucion por especie</h3>
              <p>Animales registrados en el sistema</p>
            </div>
          </div>
          <div class="chart-card-body">
            <div class="chart-container">
              <canvas id="chartEspecies" width="400" height="250" style="width:100%;height:250px;"></canvas>
            </div>
          </div>
        </div>
        <div class="chart-card">
          <div class="chart-card-header">
            <div>
              <h3>Ingresos vs Egresos</h3>
              <p>Ultimos 6 meses</p>
            </div>
          </div>
          <div class="chart-card-body">
            <div class="chart-container">
              <canvas id="chartContabilidad" width="400" height="250" style="width:100%;height:250px;"></canvas>
            </div>
          </div>
        </div>
      </div>

      <div class="chart-card mb-6">
        <div class="chart-card-header">
          <div>
            <h3>Alertas por nivel de urgencia</h3>
            <p>Distribucion de alertas activas</p>
          </div>
        </div>
        <div class="chart-card-body">
          <div class="chart-container" style="height:200px;">
            <canvas id="chartAlertas" width="400" height="200" style="width:100%;height:200px;"></canvas>
          </div>
        </div>
      </div>

      <div class="activity-grid">
        <div class="activity-card">
          <div class="activity-card-header">
            <div>
              <h3>Notificaciones recientes</h3>
              <p>Alertas y avisos del sistema</p>
            </div>
            <span class="badge-modern neutral">{totalNotifs}</span>
          </div>
          <div class="activity-card-body">
            {tieneNotifs ? (
              <div class="activity-list">
                {(data.notificaciones || []).slice(0, 5).map((n: any) => {
                  let ic = n.prioridad === 'Alta' || n.prioridad === 'Critica' ? 'urgent' : n.prioridad === 'Media' ? 'medium' : 'low';
                  return (
                    <div class={"notif-item " + ic}>
                      <div class="notif-dot"></div>
                      <div class="notif-content">
                        <p class="notif-text">{n.mensaje}</p>
                        <p class="notif-date">{n.fecha_generacion || ''}</p>
                      </div>
                    </div>
                  );
                })}
              </div>
            ) : (
              <div class="empty-small">
                <i class="fas fa-check-circle text-slate-300 text-lg"></i>
                <p>Sin notificaciones pendientes</p>
              </div>
            )}
          </div>
        </div>
        <div class="activity-card">
          <div class="activity-card-header">
            <div>
              <h3>Proximas actividades</h3>
              <p>Agenda y tareas programadas</p>
            </div>
            <span class="badge-modern neutral">{totalActs}</span>
          </div>
          <div class="activity-card-body">
            {tieneActividades ? (
              <div class="activity-list">
                {(data.actividades || []).slice(0, 5).map((a: any) => (
                  <div class="activity-item">
                    <div class="activity-icon"><i class="fas fa-calendar-day"></i></div>
                    <div class="activity-info">
                      <p class="activity-title">{a.titulo}</p>
                      <p class="activity-meta">{a.fecha}{a.hora ? ' ' + a.hora : ''}</p>
                    </div>
                    <span class="badge-modern neutral text-[10px]">{a.tipo}</span>
                  </div>
                ))}
              </div>
            ) : (
              <div class="empty-small">
                <i class="fas fa-calendar text-slate-300 text-lg"></i>
                <p>Sin actividades programadas</p>
              </div>
            )}
          </div>
        </div>
      </div>
    </>
  )}
</DashboardLayout>

<script define:vars={{ animales: data?.animales || [], contabilidad: data?.contabilidad || [], alertasLista: data?.alertasLista || [] }} is:inline>
(function() {
  var animData = animales;
  var contData = contabilidad;
  var alertData = alertasLista;

  function drawDoughnut(canvasId, labels, dataArr, colors) {
    var canvas = document.getElementById(canvasId);
    if (!canvas) return;
    var rect = canvas.parentElement.getBoundingClientRect();
    var dpr = window.devicePixelRatio || 1;
    canvas.width = rect.width * dpr;
    canvas.height = 260 * dpr;
    var ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);
    var w = rect.width, h = 260;
    var cx = w * 0.35, cy = h / 2, radius = Math.min(cx - 20, h * 0.38);
    var innerR = radius * 0.55;
    var total = dataArr.reduce(function(a, b) { return a + b; }, 0) || 1;

    var currentAngle = -Math.PI / 2;
    for (var i = 0; i < dataArr.length; i++) {
      if (dataArr[i] === 0) continue;
      var sliceAngle = (dataArr[i] / total) * Math.PI * 2;
      ctx.beginPath();
      ctx.arc(cx, cy, radius, currentAngle, currentAngle + sliceAngle);
      ctx.arc(cx, cy, innerR, currentAngle + sliceAngle, currentAngle, true);
      ctx.closePath();
      ctx.fillStyle = colors[i % colors.length];
      ctx.fill();

      // label line
      var midAngle = currentAngle + sliceAngle / 2;
      var lx = cx + Math.cos(midAngle) * (radius + 12);
      var ly = cy + Math.sin(midAngle) * (radius + 12);
      ctx.fillStyle = '#64748b';
      ctx.font = '11px system-ui, sans-serif';
      ctx.textAlign = midAngle > Math.PI / 2 && midAngle < Math.PI * 1.5 ? 'right' : 'left';
      ctx.fillText(labels[i] + ' ' + dataArr[i], lx, ly + 3);
      currentAngle += sliceAngle;
    }

    // center total
    ctx.fillStyle = '#0f172a';
    ctx.font = 'bold 22px system-ui, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(total, cx, cy - 6);
    ctx.fillStyle = '#94a3b8';
    ctx.font = '11px system-ui, sans-serif';
    ctx.fillText('Total', cx, cy + 16);
  }

  function drawBars(canvasId, labels, ingresosArr, egresosArr) {
    var canvas = document.getElementById(canvasId);
    if (!canvas) return;
    var rect = canvas.parentElement.getBoundingClientRect();
    var dpr = window.devicePixelRatio || 1;
    canvas.width = rect.width * dpr;
    canvas.height = 260 * dpr;
    var ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);
    var w = rect.width, h = 260;
    var pad = { top: 20, bottom: 35, left: 50, right: 20 };
    var chartW = w - pad.left - pad.right;
    var chartH = h - pad.top - pad.bottom;

    var allVals = ingresosArr.concat(egresosArr);
    var maxVal = Math.max.apply(null, allVals) * 1.2 || 100;
    var barW = chartW / (labels.length * 2) * 0.7;
    var gap = chartW / (labels.length * 2) * 0.3;

    // grid lines
    ctx.strokeStyle = '#f1f5f9';
    ctx.lineWidth = 1;
    for (var i = 0; i <= 4; i++) {
      var y = pad.top + chartH - (chartH * i / 4);
      ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(w - pad.right, y); ctx.stroke();
      ctx.fillStyle = '#94a3b8';
      ctx.font = '10px system-ui, sans-serif';
      ctx.textAlign = 'right';
      ctx.fillText('S/ ' + Math.round(maxVal * i / 4), pad.left - 8, y + 3);
    }

    for (var j = 0; j < labels.length; j++) {
      var xBase = pad.left + (chartW / labels.length) * j + (chartW / labels.length - barW * 2 - gap) / 2;
      var ingH = (ingresosArr[j] / maxVal) * chartH;
      var egH = (egresosArr[j] / maxVal) * chartH;

      // ingresos bar
      var x1 = xBase, y1 = pad.top + chartH - ingH;
      var grad1 = ctx.createLinearGradient(x1, y1, x1, pad.top + chartH);
      grad1.addColorStop(0, '#059669'); grad1.addColorStop(1, '#34d399');
      ctx.fillStyle = grad1;
      ctx.beginPath(); ctx.roundRect(x1, y1, barW, ingH, [3, 3, 0, 0]); ctx.fill();

      // egresos bar
      var x2 = xBase + barW + gap, y2 = pad.top + chartH - egH;
      var grad2 = ctx.createLinearGradient(x2, y2, x2, pad.top + chartH);
      grad2.addColorStop(0, '#dc2626'); grad2.addColorStop(1, '#f87171');
      ctx.fillStyle = grad2;
      ctx.beginPath(); ctx.roundRect(x2, y2, barW, egH, [3, 3, 0, 0]); ctx.fill();

      // labels
      ctx.fillStyle = '#64748b';
      ctx.font = '10px system-ui, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText(labels[j], xBase + barW + gap / 2, h - 8);
    }

    // legend
    ctx.font = '10px system-ui, sans-serif';
    ctx.textAlign = 'left';
    ctx.fillStyle = '#059669'; ctx.fillRect(w - 150, 10, 10, 10); ctx.fillStyle = '#64748b'; ctx.fillText('Ingresos', w - 134, 19);
    ctx.fillStyle = '#dc2626'; ctx.fillRect(w - 75, 10, 10, 10); ctx.fillStyle = '#64748b'; ctx.fillText('Egresos', w - 59, 19);
  }

  function drawAlertasBars(canvasId, labels, dataArr, colors) {
    if (dataArr.length === 0) return;
    var canvas = document.getElementById(canvasId);
    if (!canvas) return;
    var rect = canvas.parentElement.getBoundingClientRect();
    var dpr = window.devicePixelRatio || 1;
    canvas.width = rect.width * dpr;
    canvas.height = 200 * dpr;
    var ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);
    var w = rect.width, h = 200;
    var pad = { top: 15, bottom: 25, left: 110, right: 30 };
    var chartW = w - pad.left - pad.right;
    var chartH = h - pad.top - pad.bottom;
    var maxVal = Math.max.apply(null, dataArr) * 1.3 || 10;
    var barH = Math.min(32, chartH / dataArr.length - 6);

    for (var i = 0; i < dataArr.length; i++) {
      var y = pad.top + (chartH / dataArr.length) * i + (chartH / dataArr.length - barH) / 2;
      var barWVal = (dataArr[i] / maxVal) * chartW;
      var grad = ctx.createLinearGradient(pad.left, y, pad.left + barWVal, y);
      grad.addColorStop(0, colors[i]); grad.addColorStop(1, colors[i] + '80');
      ctx.fillStyle = grad;
      ctx.beginPath(); ctx.roundRect(pad.left, y, Math.max(barWVal, 4), barH, [0, 4, 4, 0]); ctx.fill();
      ctx.fillStyle = '#0f172a';
      ctx.font = '12px system-ui, sans-serif';
      ctx.textAlign = 'right';
      ctx.fillText(labels[i], pad.left - 10, y + barH / 2 + 4);
      ctx.textAlign = 'left';
      ctx.fillStyle = '#64748b';
      ctx.font = '11px system-ui, sans-serif';
      ctx.fillText(dataArr[i], pad.left + barWVal + 6, y + barH / 2 + 4);
    }
  }

  function initCharts() {
    // Species
    var especieMap = {};
    animData.forEach(function(a) {
      var e = a.especie || 'Otros';
      especieMap[e] = (especieMap[e] || 0) + 1;
    });
    var espLabels = Object.keys(especieMap);
    var espValues = Object.values(especieMap);
    var espColors = ['#059669','#8b5cf6','#f59e0b','#3b82f6','#ec4899','#14b8a6','#f97316'];
    drawDoughnut('chartEspecies', espLabels, espValues, espColors);

    // Contabilidad - last 6 months
    var monthMap = {};
    var months = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
    var now = new Date();
    for (var m = 0; m < 6; m++) {
      var d = new Date(now.getFullYear(), now.getMonth() - m, 1);
      var key = d.getFullYear() + '-' + (d.getMonth()+1);
      monthMap[key] = { label: months[d.getMonth()], ing: 0, eg: 0 };
    }
    contData.forEach(function(c) {
      if (!c.fecha) return;
      var parts = c.fecha.split('-');
      if (parts.length < 2) return;
      var key = parts[0] + '-' + parseInt(parts[1]);
      if (monthMap[key]) {
        var monto = parseFloat(c.monto) || 0;
        if (c.tipo === 'Ingreso') monthMap[key].ing += monto;
        else monthMap[key].eg += monto;
      }
    });
    var mbLabels = [], mbIng = [], mbEg = [];
    var keys = Object.keys(monthMap).reverse();
    keys.forEach(function(k) {
      mbLabels.push(monthMap[k].label);
      mbIng.push(Math.round(monthMap[k].ing));
      mbEg.push(Math.round(monthMap[k].eg));
    });
    drawBars('chartContabilidad', mbLabels, mbIng, mbEg);

    // Alertas por urgencia
    var urgMap = {};
    alertData.forEach(function(a) {
      var u = a.nivel_urgencia || a.estado || 'Sin especificar';
      urgMap[u] = (urgMap[u] || 0) + 1;
    });
    var urgLabels = Object.keys(urgMap);
    var urgValues = Object.values(urgMap);
    var urgColors = ['#dc2626','#f59e0b','#3b82f6','#94a3b8'];
    drawAlertasBars('chartAlertas', urgLabels, urgValues, urgColors);
  }

  document.addEventListener('DOMContentLoaded', initCharts);
  window.addEventListener('resize', initCharts);
})();
</script>

