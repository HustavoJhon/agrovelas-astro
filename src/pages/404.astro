---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pagina no encontrada">
  <div class="flex min-h-screen bg-slate-50 items-center justify-center p-4">
    <div class="text-center">
      <div class="w-24 h-24 bg-brand-100 rounded-3xl flex items-center justify-center mx-auto mb-6">
        <svg class="w-12 h-12 text-brand-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <h1 class="text-6xl font-extrabold text-slate-900 mb-2">404</h1>
      <p class="text-slate-500 text-lg mb-8">Pagina no encontrada</p>
      <a href="/" class="btn btn-primary btn-lg no-underline"><i class="fas fa-home mr-2"></i>Volver al inicio</a>
    </div>
  </div>
</Layout>
