---
import Layout from '../layouts/Layout.astro';
import { getSession } from '../lib/auth';
const session = getSession(Astro.cookies);
if (session) return Astro.redirect('/dashboard');
---

<Layout title="Crear Cuenta - AGROVELAS">
  <div class="flex min-h-screen" style="background: linear-gradient(160deg, #f8fafc 0%, #f1f5f9 50%, #e2e8f0 100%);">
    <div class="hidden lg:flex lg:w-1/2 items-center justify-center p-12" style="background: linear-gradient(160deg, #022c22 0%, #064e3b 40%, #047857 100%);">
      <div class="max-w-md text-white">
        <div class="flex items-center gap-3 mb-12"><div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/></svg></div><span class="text-xl font-bold">AGROVELAS</span></div>
        <h1 class="text-4xl font-extrabold mb-6 leading-tight">Empieza a digitalizar tu ganado</h1>
        <p class="text-brand-100/80 leading-relaxed">Crea tu cuenta gratuita y comienza a gestionar tu produccion ganadera de forma profesional.</p>
      </div>
    </div>
    <div class="flex-1 flex items-center justify-center p-6">
      <div class="w-full max-w-sm">
        <div class="mb-8 text-center lg:text-left">
          <div class="lg:hidden flex items-center gap-3 justify-center mb-8"><div class="w-10 h-10 bg-brand-600 rounded-xl flex items-center justify-center"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/></svg></div><span class="text-xl font-bold text-slate-900">AGROVELAS</span></div>
          <h2 class="text-2xl font-bold text-slate-900">Crear Cuenta</h2>
          <p class="text-sm text-slate-500 mt-1">Registrate para empezar a usar AGROVELAS</p>
        </div>
        <form id="regForm" class="space-y-4">
          <div><label class="form-label">Nombre completo</label><input id="rNom" class="form-input" placeholder="Juan Quispe Huaman" required /></div>
          <div><label class="form-label">Usuario o correo</label><input id="rLog" class="form-input" placeholder="juan@agrovelas.pe" required /></div>
          <div><label class="form-label">Contrasena</label><input id="rPass" type="password" class="form-input" placeholder="Minimo 6 caracteres" required /></div>
          <button type="submit" class="btn btn-primary w-full btn-lg">Crear Cuenta</button>
        </form>
        <p class="text-center text-sm text-slate-500 mt-6">Ya tienes cuenta? <a href="/login" class="text-brand-600 font-semibold hover:text-brand-700 no-underline">Inicia sesion</a></p>
        <p class="text-center mt-8"><a href="/" class="text-xs text-slate-400 hover:text-slate-600 no-underline"><i class="fas fa-arrow-left mr-1"></i> Volver al inicio</a></p>
      </div>
    </div>
  </div>
  <div id="toast" class="toast"></div>
</Layout>

<script is:inline>
  function showToast(m,t){var e=document.getElementById('toast');if(!e)return;e.className='toast toast-'+t;e.innerHTML=m;requestAnimationFrame(function(){e.classList.add('show')});setTimeout(function(){e.classList.remove('show')},4000)}
  document.getElementById('regForm').addEventListener('submit',function(ev){ev.preventDefault();var n=document.getElementById('rNom').value,l=document.getElementById('rLog').value,p=document.getElementById('rPass').value;if(!n||!l||!p){showToast('Completa todos los campos','error');return}if(p.length<6){showToast('La contrasena debe tener al menos 6 caracteres','error');return}fetch('/api/auth/register',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({nombre_completo:n,correo:l,usuario_login:l,contrasena:p})}).then(function(r){return r.json()}).then(function(d){if(d.error){showToast(d.error,'error');return}showToast('Cuenta creada exitosamente','success');setTimeout(function(){window.location.href='/login'},600)}).catch(function(){showToast('Error de conexion','error')})});
</script>
