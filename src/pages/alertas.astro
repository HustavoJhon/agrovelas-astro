---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getSession } from '../lib/auth';
import { readSheet } from '../lib/sheets';

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect('/login');
let alertas: any[] = [];
try { alertas = await readSheet('Animales_Alerta'); } catch (e: any) {}
const activas = alertas.filter(a => a.estado === 'En seguimiento' || a.estado === 'Derivado').length;
---

<DashboardLayout title="Alertas" userName={session.nombre} rol={session.rol} currentPage="alertas" chatData={{ alertasLista: alertas, alertas: alertas.length }}>
  <div class="page-header">
    <div><h1>Alertas Sanitarias</h1><p>Animales bajo seguimiento &middot; <span class="font-medium text-rose-600">{activas} activas</span></p></div>
    <button onclick="abrirModal()" class="btn btn-primary cursor-pointer"><i class="fas fa-plus text-xs"></i> Nueva Alerta</button>
  </div>
  {alertas.length === 0 ? (
    <div class="card"><div class="empty-state"><div class="empty-state-icon" style="background: #dcfce7; color: #059669;"><i class="fas fa-check-circle"></i></div><h3>Sin alertas activas</h3><p>Todos los animales estan en buen estado sanitario.</p></div></div>
  ) : (
    <div class="card-flush"><div class="table-wrap"><table class="table-modern"><thead><tr><th>Fecha</th><th>Animal</th><th>Sintomas</th><th>Urgencia</th><th>Zootecnista</th><th>Veterinario</th><th>Estado</th></tr></thead><tbody>
      {alertas.map((a: any) => {
        const uc = a.nivel_urgencia==='Critica'||a.nivel_urgencia==='Alta'?'danger':a.nivel_urgencia==='Media'?'warning':'info';
        const ec = a.estado==='En seguimiento'?'warning':a.estado==='Resuelto'?'success':'neutral';
        return (
          <tr><td class="text-slate-400 text-xs">{a.fecha_reporte||'-'}</td><td class="font-mono text-xs font-medium text-brand-700">{a.id_animal}</td><td class="text-xs text-slate-600 max-w-[200px] truncate">{(a.sintomas||'').substring(0,80)}</td><td><span class={"badge-modern " + uc}>{a.nivel_urgencia}</span></td><td class="text-xs text-slate-500">{a.zootecnista_asignado||'-'}</td><td class="text-xs text-slate-500">{a.veterinario_asignado||'-'}</td><td><span class={"badge-modern " + ec}>{a.estado}</span></td></tr>
        );
      })}
    </tbody></table></div></div>
  )}
  <div id="modalAle" class="modal-backdrop hidden">
    <div class="modal-content max-w-md">
      <div class="modal-header"><div><h3>Nueva Alerta Sanitaria</h3></div><button onclick="cerrarModal()" class="btn-close"><i class="fas fa-times"></i></button></div>
      <form id="aleForm">
        <div class="modal-body space-y-4">
          <div><label class="form-label">ID del Animal *</label><input id="alAni" class="form-input" required placeholder="ANI-00001" /></div>
          <div><label class="form-label">Sintomas observados *</label><textarea id="alSin" class="form-input" rows="3" required placeholder="Describe los sintomas..."></textarea></div>
          <div><label class="form-label">Nivel de Urgencia</label><select id="alUrg" class="form-input"><option>Baja</option><option>Media</option><option>Alta</option><option>Critica</option></select></div>
        </div>
        <div class="modal-footer"><button type="button" onclick="cerrarModal()" class="btn btn-secondary">Cancelar</button><button type="submit" class="btn btn-primary"><i class="fas fa-save text-xs"></i> Guardar Alerta</button></div>
      </form>
    </div>
  </div>
</DashboardLayout>
<script is:inline>
  function abrirModal() { document.getElementById('modalAle').classList.remove('hidden'); }
  function cerrarModal() { document.getElementById('modalAle').classList.add('hidden'); }
  document.getElementById('aleForm').addEventListener('submit', function(e) { e.preventDefault(); var d = { id_animal: document.getElementById('alAni').value, sintomas: document.getElementById('alSin').value, nivel_urgencia: document.getElementById('alUrg').value, estado: 'En seguimiento', fecha_reporte: new Date().toISOString().replace('T',' ').substring(0,16) }; if (!d.id_animal || !d.sintomas) { showToast('Completa los campos', 'error'); return; }     fetch('/api/data/Animales_Alerta', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(d) }).then(r=>r.json()).then(d=>{ if(d.error){showToast(d.error,'error');return;} cerrarModal(); showToast('Alerta registrada','success'); setTimeout(function(){location.reload();},500); }).catch(function(){ showToast('Error de conexion','error'); }); });
</script>
