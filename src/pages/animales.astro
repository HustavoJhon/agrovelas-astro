---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getSession } from '../lib/auth';
import { readSheet } from '../lib/sheets';

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect('/login');

let animales: any[] = [];
let errorMsg = '';
try { animales = await readSheet('Animales'); } catch (e: any) { errorMsg = e.message; }
---

<DashboardLayout title="Animales" userName={session.nombre} rol={session.rol} currentPage="animales">
  <div class="page-header">
    <div>
      <h1>Animales</h1>
      <p>Registro y gestion de tu ganado &middot; <span class="font-medium">{animales.length} registrados</span></p>
    </div>
    <button onclick="abrirModalAnimal()" class="btn btn-primary cursor-pointer"><i class="fas fa-plus text-xs"></i> Nuevo Animal</button>
  </div>

  {errorMsg ? (
    <div class="card p-5 bg-red-50 border-red-200 text-red-700 text-sm">{errorMsg}</div>
  ) : animales.length === 0 ? (
    <div class="card">
      <div class="empty-state">
        <div class="empty-state-icon"><i class="fas fa-paw"></i></div>
        <h3>Sin animales registrados</h3>
        <p>Comienza agregando tu primer animal al sistema.</p>
        <button onclick="abrirModalAnimal()" class="btn btn-primary cursor-pointer"><i class="fas fa-plus text-xs"></i> Registrar primer animal</button>
      </div>
    </div>
  ) : (
    <div class="card-flush">
      <div class="table-wrap">
        <table class="table-modern">
          <thead>
            <tr><th>ID</th><th>Nombre</th><th>Especie</th><th>Raza</th><th>Sexo</th><th>Fecha Nac.</th><th>Lote</th><th>Estado</th></tr>
          </thead>
          <tbody>
            {animales.map((a: any) => {
              const ec = a.estado === 'Activo' ? 'success' : a.estado === 'Vendido' ? 'warning' : 'danger';
              return (
                <tr>
                  <td class="font-mono text-xs font-medium text-brand-700">{a.id_animal}</td>
                  <td class="font-medium text-slate-800">{a.nombre || '-'}</td>
                  <td><span class="badge-modern info">{a.especie}</span></td>
                  <td class="text-slate-500">{a.raza || '-'}</td>
                  <td class="text-slate-500">{a.sexo || '-'}</td>
                  <td class="text-slate-400 text-xs">{a.fecha_nacimiento || '-'}</td>
                  <td class="font-mono text-xs text-slate-400">{a.id_lote_cabana || '-'}</td>
                  <td><span class={"badge-modern " + ec}>{a.estado}</span></td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  )}

  <div id="animalModal" class="modal-backdrop hidden">
    <div class="modal-content max-w-2xl">
      <div class="modal-header">
        <div><h3>Nuevo Animal</h3><p>Completa la informacion basica del animal</p></div>
        <button onclick="cerrarModalAnimal()" class="btn-close"><i class="fas fa-times"></i></button>
      </div>
      <form id="animalForm">
        <div class="modal-body">
          <div class="fields-grid">
            <div class="span-2"><label class="form-label">Especie *</label><select id="fEsp" class="form-input" required><option value="">Seleccionar...</option><option>Alpaca</option><option>Llama</option><option>Oveja</option><option>Bovino</option><option>Caprino</option></select></div>
            <div><label class="form-label">Sexo *</label><select id="fSexo" class="form-input" required><option value="">Seleccionar...</option><option>Macho</option><option>Hembra</option></select></div>
            <div><label class="form-label">Raza</label><input id="fRaza" class="form-input" placeholder="Huacaya, Suri, Corriedale..." /></div>
            <div><label class="form-label">Nombre / Apodo</label><input id="fNom" class="form-input" placeholder="Luna" /></div>
            <div><label class="form-label">Fecha de Nacimiento</label><input id="fNac" type="date" class="form-input" /></div>
            <div><label class="form-label">Color principal</label><input id="fCol" class="form-input" placeholder="Blanco, Marron..." /></div>
            <div><label class="form-label">ID del Padre</label><input id="fPad" class="form-input" placeholder="ANI-00001" /></div>
            <div><label class="form-label">ID de la Madre</label><input id="fMad" class="form-input" placeholder="ANI-00002" /></div>
            <div><label class="form-label">Linea Genetica</label><input id="fLin" class="form-input" placeholder="Linea Pacomarca 3" /></div>
            <div><label class="form-label">Procedencia</label><select id="fProc" class="form-input"><option>Nacido en predio</option><option>Comprado</option><option>Donado</option></select></div>
            <div><label class="form-label">Codigo Arete / RFID</label><input id="fArete" class="form-input" placeholder="ARQ-1001" /></div>
            <div><label class="form-label">Lote / Cabana</label><input id="fLote" class="form-input" placeholder="LOT-00001" /></div>
            <div class="span-2"><label class="form-label">Observaciones</label><textarea id="fObs" class="form-input" rows="2" placeholder="Notas adicionales..."></textarea></div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" onclick="cerrarModalAnimal()" class="btn btn-secondary">Cancelar</button>
          <button type="submit" class="btn btn-primary"><i class="fas fa-save text-xs"></i> Guardar Animal</button>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<script is:inline>
  function abrirModalAnimal() { document.getElementById('animalModal').classList.remove('hidden'); }
  function cerrarModalAnimal() { document.getElementById('animalModal').classList.add('hidden'); }
  document.getElementById('animalForm').addEventListener('submit', function(e) {
    e.preventDefault();
    var datos = {
      especie: document.getElementById('fEsp').value, raza: document.getElementById('fRaza').value,
      sexo: document.getElementById('fSexo').value, nombre: document.getElementById('fNom').value,
      fecha_nacimiento: document.getElementById('fNac').value, color_principal: document.getElementById('fCol').value,
      id_padre: document.getElementById('fPad').value, id_madre: document.getElementById('fMad').value,
      linea_genetica: document.getElementById('fLin').value, procedencia: document.getElementById('fProc').value,
      codigo_arete_rfid: document.getElementById('fArete').value, id_lote_cabana: document.getElementById('fLote').value,
      observaciones_generales: document.getElementById('fObs').value,
    };
    if (!datos.especie || !datos.sexo) { showToast('Completa especie y sexo', 'error'); return; }
    fetch('/api/data/animales/registro', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(datos) })
      .then(function(r) { return r.json(); })
      .then(function(d) { if (d.error) { showToast(d.error, 'error'); return; } cerrarModalAnimal(); showToast('Animal registrado: ' + d.id_animal, 'success'); setTimeout(function(){ location.reload(); }, 500); })
      .catch(function() { showToast('Error de conexion', 'error'); });
  });
</script>
