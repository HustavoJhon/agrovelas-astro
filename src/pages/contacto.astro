---
import Layout from '../layouts/Layout.astro';
import LandingNav from '../components/LandingNav.astro';
import LandingFooter from '../components/LandingFooter.astro';
---

<Layout title="Contacto - AGROVELAS">
  <LandingNav current="/contacto" />

  <section class="py-20" style="background: linear-gradient(160deg, #022c22 0%, #064e3b 40%, #047857 100%);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <h1 class="text-4xl sm:text-5xl font-extrabold mb-6">Contacto</h1>
      <p class="text-lg text-brand-100/80 max-w-2xl mx-auto">Estamos para ayudarte. Respondemos en menos de 24 horas.</p>
    </div>
  </section>

  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-16">
      <div>
        <div class="text-xs font-semibold text-brand-600 uppercase tracking-widest mb-3">Escribenos</div>
        <h2 class="text-2xl font-bold text-slate-900 mb-6">Ponte en contacto</h2>
        <form id="contactForm" class="space-y-4">
          <div><label class="form-label">Nombre completo *</label><input id="cNom" class="form-input" required placeholder="Tu nombre" /></div>
          <div><label class="form-label">Correo electronico *</label><input id="cCor" type="email" class="form-input" required placeholder="correo@ejemplo.pe" /></div>
          <div><label class="form-label">Asunto</label><input id="cAsu" class="form-input" placeholder="Asunto del mensaje" /></div>
          <div><label class="form-label">Mensaje *</label><textarea id="cMsg" class="form-input" rows="5" required placeholder="Describe tu consulta o sugerencia..."></textarea></div>
          <button type="submit" class="btn btn-primary w-full btn-lg">Enviar mensaje <i class="fas fa-paper-plane text-xs"></i></button>
        </form>
        <div id="toast" class="toast"></div>
      </div>
      <div>
        <div class="text-xs font-semibold text-brand-600 uppercase tracking-widest mb-3">Informacion</div>
        <h2 class="text-2xl font-bold text-slate-900 mb-6">Otros canales</h2>
        <div class="space-y-6">
          <div class="flex items-start gap-4 p-5 rounded-xl bg-slate-50">
            <div class="w-11 h-11 rounded-xl bg-brand-100 flex items-center justify-center shrink-0"><i class="fas fa-envelope text-brand-600"></i></div>
            <div><p class="font-semibold text-slate-900 text-sm">Correo electronico</p><p class="text-sm text-slate-500 mt-0.5">contacto@agrovelas.pe</p></div>
          </div>
          <div class="flex items-start gap-4 p-5 rounded-xl bg-slate-50">
            <div class="w-11 h-11 rounded-xl bg-blue-100 flex items-center justify-center shrink-0"><i class="fas fa-map-marker-alt text-blue-600"></i></div>
            <div><p class="font-semibold text-slate-900 text-sm">Ubicacion</p><p class="text-sm text-slate-500 mt-0.5">Cusco, Peru &middot; Corazon de los Andes</p></div>
          </div>
          <div class="flex items-start gap-4 p-5 rounded-xl bg-slate-50">
            <div class="w-11 h-11 rounded-xl bg-purple-100 flex items-center justify-center shrink-0"><i class="fas fa-clock text-purple-600"></i></div>
            <div><p class="font-semibold text-slate-900 text-sm">Horario de atencion</p><p class="text-sm text-slate-500 mt-0.5">Lun - Vie: 9:00 AM - 6:00 PM</p></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <LandingFooter />
</Layout>

<script is:inline>
  function showToast(m,t){var e=document.getElementById('toast');if(!e)return;e.className='toast toast-'+t;e.innerHTML=m;requestAnimationFrame(function(){e.classList.add('show')});setTimeout(function(){e.classList.remove('show')},4000)}
  document.getElementById('contactForm').addEventListener('submit',function(e){e.preventDefault();var d={nombre:document.getElementById('cNom').value,correo:document.getElementById('cCor').value,asunto:document.getElementById('cAsu').value,mensaje:document.getElementById('cMsg').value};if(!d.nombre||!d.correo||!d.mensaje){showToast('Completa nombre, correo y mensaje','error');return}showToast('Mensaje enviado con exito. Te responderemos pronto.','success');this.reset()});
</script>
