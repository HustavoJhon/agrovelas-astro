---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getSession } from '../lib/auth';
import { readSheet } from '../lib/sheets';

const session = getSession(Astro.cookies);
if (!session) return Astro.redirect('/login');
let registros: any[] = [];
try { registros = await readSheet('Contabilidad'); } catch (e: any) {}
let ingresos = 0, egresos = 0;
registros.forEach(m => { const v = isNaN(parseFloat(m.monto))?0:parseFloat(m.monto); if(m.tipo==='Ingreso') ingresos+=v; else egresos+=v; });
const balPos = (ingresos-egresos)>=0;
---

<DashboardLayout title="Contabilidad" userName={session.nombre} rol={session.rol} currentPage="contabilidad" chatData={{ contabilidad: registros }}>
  <div class="page-header">
    <div><h1>Contabilidad</h1><p>Ingresos y egresos del predio &middot; <span class="font-medium">{registros.length} movimientos</span></p></div>
    <button onclick="abrirModal()" class="btn btn-primary cursor-pointer"><i class="fas fa-plus text-xs"></i> Nuevo Movimiento</button>
  </div>
  <div class="stagger grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
    <div class="grad-emerald text-white rounded-xl p-5 shadow-lg"><p class="stat-label">Ingresos</p><p class="stat-value mt-1">S/ {ingresos.toFixed(2)}</p></div>
    <div class="grad-rose text-white rounded-xl p-5 shadow-lg"><p class="stat-label">Egresos</p><p class="stat-value mt-1">S/ {egresos.toFixed(2)}</p></div>
    <div class={"rounded-xl p-5 shadow-lg text-white " + (balPos ? 'grad-emerald' : 'grad-rose')}><p class="stat-label">Balance</p><p class="stat-value mt-1">S/ {(ingresos-egresos).toFixed(2)}</p></div>
  </div>
  {registros.length === 0 ? (
    <div class="card"><div class="empty-state"><div class="empty-state-icon"><i class="fas fa-coins"></i></div><h3>Sin movimientos contables</h3><p>Registra ingresos y egresos para llevar el control financiero.</p><button onclick="abrirModal()" class="btn btn-primary cursor-pointer"><i class="fas fa-plus text-xs"></i> Nuevo movimiento</button></div></div>
  ) : (
    <div class="card-flush"><div class="table-wrap"><table class="table-modern"><thead><tr><th>Fecha</th><th>Tipo</th><th>Categoria</th><th>Monto</th><th>Descripcion</th></tr></thead><tbody>
      {registros.map((c: any) => {
        const tc = c.tipo==='Ingreso'?'success':'danger';
        const mc = c.tipo==='Ingreso'?'text-brand-700':'text-rose-700';
        return (
          <tr><td class="text-slate-400 text-xs">{c.fecha||'-'}</td><td><span class={"badge-modern " + tc}>{c.tipo}</span></td><td class="text-slate-700">{c.categoria||'-'}</td><td class={"font-semibold " + mc}>S/ {c.monto||'0.00'}</td><td class="text-xs text-slate-400">{c.descripcion||'-'}</td></tr>
        );
      })}
    </tbody></table></div></div>
  )}
  <div id="modalCtb" class="modal-backdrop hidden">
    <div class="modal-content max-w-md">
      <div class="modal-header"><div><h3>Nuevo Movimiento Contable</h3></div><button onclick="cerrarModal()" class="btn-close"><i class="fas fa-times"></i></button></div>
      <form id="ctbForm">
        <div class="modal-body space-y-4">
          <div class="grid grid-cols-2 gap-4"><div><label class="form-label">Tipo</label><select id="ctTip" class="form-input"><option>Ingreso</option><option>Egreso</option></select></div><div><label class="form-label">Monto S/ *</label><input id="ctMon" type="number" step="0.01" class="form-input" required /></div></div>
          <div><label class="form-label">Categoria</label><input id="ctCat" class="form-input" placeholder="Venta de fibra, Honorarios..." /></div>
          <div><label class="form-label">Fecha *</label><input id="ctFec" type="date" class="form-input" required /></div>
        </div>
        <div class="modal-footer"><button type="button" onclick="cerrarModal()" class="btn btn-secondary">Cancelar</button><button type="submit" class="btn btn-primary"><i class="fas fa-save text-xs"></i> Guardar</button></div>
      </form>
    </div>
  </div>
</DashboardLayout>
<script is:inline>
  function abrirModal() { document.getElementById('modalCtb').classList.remove('hidden'); }
  function cerrarModal() { document.getElementById('modalCtb').classList.add('hidden'); }
  document.getElementById('ctbForm').addEventListener('submit', function(e) { e.preventDefault(); var d = { fecha: document.getElementById('ctFec').value, tipo: document.getElementById('ctTip').value, categoria: document.getElementById('ctCat').value, monto: document.getElementById('ctMon').value }; if (!d.fecha || !d.monto) { showToast('Completa fecha y monto', 'error'); return; }     fetch('/api/data/Contabilidad', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(d) }).then(r=>r.json()).then(d=>{ if(d.error){showToast(d.error,'error');return;} cerrarModal(); showToast('Movimiento registrado','success'); setTimeout(function(){location.reload();},500); }).catch(function(){ showToast('Error de conexion','error'); }); });
</script>
