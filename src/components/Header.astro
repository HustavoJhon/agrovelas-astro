---
interface Props {
  userName: string;
  pageTitle: string;
}

const { userName, pageTitle } = Astro.props;
---

<header class="sticky top-0 z-30 bg-white border-b border-slate-100 shrink-0">
  <div class="flex items-center justify-between px-4 sm:px-6 h-14">
    <div class="flex items-center gap-3 min-w-0">
      <button id="menuBtn" class="lg:hidden w-9 h-9 rounded-lg hover:bg-slate-100 flex items-center justify-center text-slate-500 transition-colors shrink-0">
        <i class="fas fa-bars text-sm"></i>
      </button>
      <div class="flex items-center gap-2 text-sm min-w-0">
        <span class="text-slate-400 shrink-0">AGROVELAS</span>
        <span class="text-slate-300 shrink-0">/</span>
        <span class="text-slate-700 font-medium truncate">{pageTitle}</span>
      </div>
    </div>
    <div class="flex items-center gap-3 shrink-0">
      <div class="text-right hidden sm:block">
        <p class="text-sm font-medium text-slate-700 leading-tight">{userName}</p>
        <p class="text-[11px] text-slate-400">Conectado</p>
      </div>
      <div class="w-8 h-8 rounded-lg bg-brand-100 flex items-center justify-center text-brand-700 font-bold text-xs shrink-0">
        {userName.charAt(0).toUpperCase()}
      </div>
    </div>
  </div>
</header>
