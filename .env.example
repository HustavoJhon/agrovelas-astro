# === AGROVELAS - Variables de Entorno ===
# Todas son REQUERIDAS para conectar con Google Sheets.

# ID del Google Sheet (de la URL: /d/XXXXX/edit)
GOOGLE_SHEET_ID=tu_sheet_id_aqui

# Credenciales de Service Account de Google Cloud
# GOOGLE_CLIENT_EMAIL = client_email del JSON descargado
GOOGLE_CLIENT_EMAIL=agrovelas-service@tu-proyecto.iam.gserviceaccount.com

# GOOGLE_PRIVATE_KEY = private_key del JSON descargado
# Importante: en Vercel, pega la key TAL CUAL (con saltos de linea \n).
# El sistema reemplazara \n por saltos de linea reales automaticamente.
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----
